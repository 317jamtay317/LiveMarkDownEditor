# ---------------------------------------------
# .gitignore for a .NET application in JetBrains Rider
# ---------------------------------------------

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# .NET
project.lock.json
project.fragment.lock.json
artifacts/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# Build tool / compiler
*.tlog
*.pidb
*.svclog
*.scc

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
.nuget/

# MSBuild binary and structured logs
*.binlog

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info
TestResults/
.coverage/

# ---------------------------------------------
# JetBrains Rider
# ---------------------------------------------
# Rider stores project-specific settings under .idea/.
# Ignore the entire folder.
.idea/
*.iml

# Rider / ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# ---------------------------------------------
# OS-generated files
# ---------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------
# Logs
# ---------------------------------------------
# Serilog (and any other) log output.
logs/

# ---------------------------------------------
# Misc
# ---------------------------------------------
*.tmp
*.bak
*.cache

# Advanced Installer build cache
installer/*-cache/
installer/Setup Files/
