<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:UI.Controls">

    <!-- Default style for the Navigation Panel. Authored as the control's ResourceDictionary alongside
         the OutlinePanel class, per the project's Control conventions. Colours are DynamicResource
         lookups into the active palette so the panel follows the light/dark theme. -->

    <controls:HeadingLevelToIndentConverter x:Key="HeadingLevelToIndentConverter" />
    <BooleanToVisibilityConverter x:Key="OutlineBoolToVisibility" />

    <!-- The Collapse toggle beside an Outline Entry that leads nested entries: pointing down (▾) when
         Expanded, right (▸) when Collapsed — the same convention as the Editor Gutter's Fold Toggle.
         Foreground is inherited from the row so it stays legible on the accent-filled Current Section. -->
    <Style x:Key="OutlineChevron" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Content" Value="&#x25BE;" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                <Setter Property="Content" Value="&#x25B8;" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- One Outline Entry: a Collapse toggle (only when it leads nested entries) and the heading text,
         the row indented by its heading level; accent-filled when it is the Current Section. -->
    <Style x:Key="OutlineEntry" TargetType="ListBoxItem">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="5"
                            Padding="4,5" Margin="2,1">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:OutlinePanel}" BasedOn="{StaticResource {x:Type ListBox}}">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource OutlineEntry}" />
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid Margin="{Binding Level, Converter={StaticResource HeadingLevelToIndentConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource OutlineChevron}" Focusable="False"
                                Command="{Binding ToggleCollapseCommand}"
                                Visibility="{Binding LeadsNestedEntries, Converter={StaticResource OutlineBoolToVisibility}}" />
                        <TextBlock Grid.Column="1" Text="{Binding Text}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
