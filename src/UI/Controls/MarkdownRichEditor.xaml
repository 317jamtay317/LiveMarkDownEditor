<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:UI.Controls">

    <!-- Default style for the WYSIWYG editing surface. Authored as the control's ResourceDictionary
         alongside the MarkdownRichEditor class, per the project's Control conventions. -->
    <Style TargetType="{x:Type controls:MarkdownRichEditor}"
           BasedOn="{StaticResource {x:Type RichTextBox}}">
        <Setter Property="Padding" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="AcceptsTab" Value="True" />
        <Setter Property="SpellCheck.IsEnabled" Value="True" />
    </Style>

</ResourceDictionary>
