<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:UI.Controls">

    <!-- Default style for the Source Gutter. Authored as the control's ResourceDictionary alongside
         the SourceGutter class, per the project's Control conventions. Colours are DynamicResource
         lookups into the active palette so the gutter follows the light/dark theme. -->
    <Style TargetType="{x:Type controls:SourceGutter}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}" />
        <Setter Property="LineNumberBrush" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

</ResourceDictionary>
