<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:UI.Controls">

    <!-- Default style for the Command Tip. Authored as the control's ResourceDictionary alongside the
         CommandTip class, per the project's Control conventions. Every colour is a DynamicResource
         lookup into the active palette, so the tip follows the light/dark theme instead of falling
         back to WPF's pale, system-drawn tooltip chrome — the same reason Themes/Controls.xaml
         re-styles the stock TextBox and ComboBox. -->
    <Style TargetType="{x:Type controls:CommandTip}">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="11,8" />
        <Setter Property="MaxWidth" Value="300" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="Placement" Value="Bottom" />
        <Setter Property="VerticalOffset" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CommandTip}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.22" BlurRadius="14" ShadowDepth="2" />
                        </Border.Effect>
                        <StackPanel MaxWidth="260">
                            <!-- Heading row: the action's Name, with its key gesture as a chip pinned right. -->
                            <DockPanel LastChildFill="True">
                                <Border x:Name="GestureChip" DockPanel.Dock="Right" Margin="10,1,0,0"
                                        VerticalAlignment="Top" Background="{DynamicResource HoverBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="6,1">
                                    <TextBlock Text="{TemplateBinding Gesture}" FontSize="11"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </Border>
                                <TextBlock Text="{TemplateBinding Heading}" FontSize="13" FontWeight="SemiBold"
                                           TextWrapping="Wrap" VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}" />
                            </DockPanel>
                            <!-- Detail: a plain-language line on what the action does. -->
                            <TextBlock x:Name="DetailText" Text="{TemplateBinding Detail}" Margin="0,3,0,0"
                                       FontSize="12" TextWrapping="Wrap"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- No gesture / no detail: collapse that piece so the tip is only as tall as
                             it needs to be. Default values are empty (never null), so a plain string
                             equality trigger fires. -->
                        <Trigger Property="Gesture" Value="">
                            <Setter TargetName="GestureChip" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Detail" Value="">
                            <Setter TargetName="DetailText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
