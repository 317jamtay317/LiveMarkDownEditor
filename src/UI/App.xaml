<Application x:Class="UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:UI.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- The active palette (Palette.Light/Dark) is merged at runtime by WpfThemeService.
                     Control styles reference palette brushes via DynamicResource, so it need not be
                     present at parse time. -->
                <!-- Icons before Controls: the CommandIcon style resolves its Data by StaticResource. -->
                <ResourceDictionary Source="Themes/Icons.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
                <ResourceDictionary Source="Themes/Scrollbars.xaml" />
                <ResourceDictionary Source="Controls/MarkdownRichEditor.xaml" />
                <ResourceDictionary Source="Controls/EditorGutter.xaml" />
                <ResourceDictionary Source="Controls/SourceGutter.xaml" />
                <ResourceDictionary Source="Controls/OutlinePanel.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <controls:BooleanToGridLengthConverter x:Key="BooleanToGridLengthConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
