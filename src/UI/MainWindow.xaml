<Window x:Class="UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:UI.Controls"
        xmlns:core="clr-namespace:UI.Core"
        xmlns:viewModels="clr-namespace:UI.ViewModels"
        mc:Ignorable="d"
        Title="{Binding ActiveSession.Title, StringFormat='{}{0} — LiveMarkDownEditor', FallbackValue='LiveMarkDownEditor'}"
        Icon="pack://application:,,,/Assets/app.ico"
        Height="680" Width="1120"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        TextOptions.TextFormattingMode="Ideal">

    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="N" Command="{Binding NewCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="O" Command="{Binding OpenCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="W" Command="{Binding CloseSessionCommand}"
                    CommandParameter="{Binding ActiveSession}" />
        <KeyBinding Modifiers="Ctrl" Key="P" Command="controls:MarkdownEditingCommands.Print"
                    CommandTarget="{Binding ElementName=Editor}" />
        <KeyBinding Modifiers="Ctrl+Shift" Key="P" Command="controls:MarkdownEditingCommands.PrintPreview"
                    CommandTarget="{Binding ElementName=Editor}" />
        <KeyBinding Modifiers="Ctrl" Key="F" Command="controls:MarkdownEditingCommands.ShowFind"
                    CommandTarget="{Binding ElementName=Editor}" />
        <!-- Escape dismisses the open Panel Flyout (INV-062). The editor handles Escape itself while
             the Find Bar is open, and with no flyout the command cannot execute, so the key falls
             through untouched everywhere else. -->
        <KeyBinding Key="Escape" Command="{Binding DismissFlyoutCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <!-- An Auto-Hide Tab: the sideways button an Auto-Hide Bar shows for one Auto-Hidden panel.
             Activating it opens (or dismisses) that panel's Panel Flyout (INV-062). -->
        <DataTemplate x:Key="AutoHideTabButton">
            <Button Margin="0,0,0,8" Padding="4,10" Background="Transparent" Focusable="False"
                    Command="{Binding DataContext.ToggleFlyoutCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Panel}"
                    AutomationProperties.Name="{Binding Title, StringFormat='Open the {0} panel'}">
                <Button.ToolTip>
                    <controls:CommandTip Heading="{Binding Title}"
                                         Detail="Slide the panel out over the editor. Pin it there to dock it again." />
                </Button.ToolTip>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabChrome" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background"
                                        Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock Text="{Binding Title}" FontSize="12"
                           Foreground="{DynamicResource MutedTextBrush}">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="90" />
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Single command bar: file actions, formatting, and the theme toggle. The Insert and View
             groups show their individual icons while they fit and collapse to a dropdown only when the
             row would run off-screen (INV-054); CommandBarPanel does that measuring. -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" ClipToBounds="True">
            <controls:CommandBarPanel Margin="8,6">
                <Button DockPanel.Dock="Left" Style="{StaticResource IconCommandButton}"
                        Command="{Binding NewCommand}"
                        AutomationProperties.Name="New document">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="New document"
                                             Detail="Start a new, empty document in a new tab." Gesture="Ctrl+N" />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.New}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconCommandButton}"
                        Command="{Binding OpenCommand}"
                        AutomationProperties.Name="Open a Markdown file">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Open"
                                             Detail="Open a Markdown file from your computer in a new tab." Gesture="Ctrl+O" />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Open}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconCommandButton}"
                        Command="{Binding Folder.OpenFolderCommand}"
                        AutomationProperties.Name="Open a folder">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Open folder"
                                             Detail="Browse a folder's Markdown files as a tree in the side panel." />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.OpenFolder}" />
                </Button>

                <!-- Open Recent: the recently opened or saved files, newest first (INV-037). -->
                <Menu DockPanel.Dock="Left" Style="{StaticResource CommandMenu}">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              AutomationProperties.Name="Open recent"
                              ItemsSource="{Binding RecentFiles}">
                        <MenuItem.ToolTip>
                            <controls:CommandTip Heading="Open recent"
                                                 Detail="Reopen a file you recently opened or saved." />
                        </MenuItem.ToolTip>
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.OpenRecent}" />
                        </MenuItem.Header>
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem" BasedOn="{StaticResource CommandMenuEntry}">
                                <Setter Property="Header" Value="{Binding}" />
                                <!-- The full path on hover — themed by the implicit ToolTip style, and
                                     shown even when disabled via the CommandMenuEntry base. A dynamic
                                     list can't carry a shared CommandTip instance per item, so this
                                     one leaf uses a plain (path) tooltip rather than a heading/detail. -->
                                <Setter Property="ToolTip" Value="{Binding}" />
                                <Setter Property="Command"
                                        Value="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=Menu}}" />
                                <Setter Property="CommandParameter" Value="{Binding}" />
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                </Menu>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconCommandButton}"
                        Command="{Binding SaveCommand}"
                        AutomationProperties.Name="Save">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Save"
                                             Detail="Save this document to its file." Gesture="Ctrl+S" />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Save}" />
                </Button>
                <!-- Export Menu: the ways a finished document leaves the editor, under one Command Icon.
                     The entries stay words, like the Heading and Table dropdowns; Print keeps its Ctrl+P
                     gesture (bound on the window) and is not itself an Export (INV-034). -->
                <Menu DockPanel.Dock="Left" Style="{StaticResource CommandMenu}">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              AutomationProperties.Name="Export">
                        <MenuItem.ToolTip>
                            <controls:CommandTip Heading="Export"
                                                 Detail="Export the document as HTML or PDF, or send it to a printer." />
                        </MenuItem.ToolTip>
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ExportHtml}" />
                        </MenuItem.Header>
                        <!-- The Command Bar's DataContext (the Workspace) does not flow into a templated
                             MenuItem's Popup, so reach it by RelativeSource — the same form the Open
                             Recent menu uses. Print below is a routed command and needs no DataContext. -->
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Export as HTML"
                                  Command="{Binding DataContext.Export.ExportHtmlCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  CommandParameter="{Binding DataContext.ActiveSession, RelativeSource={RelativeSource AncestorType=Menu}}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Export as HTML"
                                                     Detail="Save the document as an HTML file — a standalone page or a fragment." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ExportHtml}" />
                                    <TextBlock Text="Export as HTML…" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Export as PDF"
                                  Command="{Binding DataContext.Export.ExportPdfCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  CommandParameter="{Binding DataContext.ActiveSession, RelativeSource={RelativeSource AncestorType=Menu}}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Export as PDF"
                                                     Detail="Save the document as a PDF file, re-laid-out from the Markdown." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ExportPdf}" />
                                    <TextBlock Text="Export as PDF…" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Print preview"
                                  Command="controls:MarkdownEditingCommands.PrintPreview"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Print preview"
                                                     Detail="See the document laid out into the pages Print would produce." Gesture="Ctrl+Shift+P" />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.PrintPreview}" />
                                    <TextBlock Text="Print preview…  (Ctrl+Shift+P)" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Print"
                                  Command="controls:MarkdownEditingCommands.Print"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Print"
                                                     Detail="Send the document to a printer, or to Microsoft Print to PDF." Gesture="Ctrl+P" />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Print}" />
                                    <TextBlock Text="Print…  (Ctrl+P)" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <Rectangle DockPanel.Dock="Left" Style="{StaticResource CommandSeparator}" />

                <!-- Heading Level Picker. Like the Table dropdown, its entries keep their words: six
                     near-identical glyphs would separate the levels far less than the words do. -->
                <Menu DockPanel.Dock="Left" Style="{StaticResource CommandMenu}">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              AutomationProperties.Name="Heading level">
                        <MenuItem.ToolTip>
                            <controls:CommandTip Heading="Heading level"
                                                 Detail="Make the current line a heading (Ctrl+1–6), or a normal paragraph again (Ctrl+0)." />
                        </MenuItem.ToolTip>
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.SetHeadingLevel}" />
                        </MenuItem.Header>
                        <!-- Paragraph leads the list: Set Heading Level never toggles, so this is a
                             Heading's only way back to plain text (INV-027). Trailing the levels, it
                             read as an afterthought and was missed. -->
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Paragraph  (Ctrl+0)"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="0" CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Paragraph"
                                                     Detail="Turn the heading at the cursor back into normal text." Gesture="Ctrl+0" />
                            </MenuItem.ToolTip>
                        </MenuItem>
                        <Separator />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 1  (Ctrl+1)"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="1" CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Heading 1"
                                                     Detail="Make the current line a top-level heading." Gesture="Ctrl+1" />
                            </MenuItem.ToolTip>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 2  (Ctrl+2)"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="2" CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Heading 2"
                                                     Detail="Make the current line a level-2 heading." Gesture="Ctrl+2" />
                            </MenuItem.ToolTip>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 3  (Ctrl+3)"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="3" CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Heading 3"
                                                     Detail="Make the current line a level-3 heading." Gesture="Ctrl+3" />
                            </MenuItem.ToolTip>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 4  (Ctrl+4)"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="4" CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Heading 4"
                                                     Detail="Make the current line a level-4 heading." Gesture="Ctrl+4" />
                            </MenuItem.ToolTip>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 5  (Ctrl+5)"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="5" CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Heading 5"
                                                     Detail="Make the current line a level-5 heading." Gesture="Ctrl+5" />
                            </MenuItem.ToolTip>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 6  (Ctrl+6)"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="6" CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Heading 6"
                                                     Detail="Make the current line a level-6 heading." Gesture="Ctrl+6" />
                            </MenuItem.ToolTip>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        AutomationProperties.Name="Bold"
                        Command="EditingCommands.ToggleBold" CommandTarget="{Binding ElementName=Editor}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Bold"
                                             Detail="Make the selected text bold, or turn bold text back to normal." Gesture="Ctrl+B" />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleBold}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        AutomationProperties.Name="Italic"
                        Command="EditingCommands.ToggleItalic" CommandTarget="{Binding ElementName=Editor}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Italic"
                                             Detail="Italicize the selected text, or turn italic text back to normal." Gesture="Ctrl+I" />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleItalic}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        AutomationProperties.Name="Strikethrough"
                        Command="controls:MarkdownEditingCommands.ToggleStrikethrough"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Strikethrough"
                                             Detail="Draw a line through the selected text, or remove it." />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleStrikethrough}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        AutomationProperties.Name="Code"
                        Command="controls:MarkdownEditingCommands.ToggleCode"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Code"
                                             Detail="Format the selection as code — inline on one line, a block across several. Click inside code to remove it." />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleCode}" />
                </Button>

                <!-- List Picker: the three List Formatting Actions under one Command Icon. The entries
                     stay words, like the Heading and Table dropdowns. -->
                <Menu DockPanel.Dock="Left" Style="{StaticResource CommandMenu}">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              AutomationProperties.Name="List">
                        <MenuItem.ToolTip>
                            <controls:CommandTip Heading="List"
                                                 Detail="Turn the selected lines into a bulleted, numbered, or checklist — or back into paragraphs." />
                        </MenuItem.ToolTip>
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleUnorderedList}" />
                        </MenuItem.Header>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Bulleted list"
                                  Command="controls:MarkdownEditingCommands.ToggleUnorderedList"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Bulleted list"
                                                     Detail="Turn the selected lines into a bulleted list, or back into paragraphs." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleUnorderedList}" />
                                    <TextBlock Text="Bulleted list" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Numbered list"
                                  Command="controls:MarkdownEditingCommands.ToggleOrderedList"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Numbered list"
                                                     Detail="Turn the selected lines into a numbered list, or back into paragraphs." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleOrderedList}" />
                                    <TextBlock Text="Numbered list" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Checklist"
                                  Command="controls:MarkdownEditingCommands.ToggleTaskList"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Checklist"
                                                     Detail="Turn the selected lines into a checklist with tickable boxes." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleTaskList}" />
                                    <TextBlock Text="Checklist" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <!-- Insert group — expanded form: the individual insert icons, shown while the row is wide
                     enough. When it would overflow they collapse to the Insert dropdown below, which shares
                     OverflowGroup="Insert" (INV-054). CollapseOrder 1 collapses it after the View group. -->
                <Button Style="{StaticResource IconFormatButton}"
                        controls:CommandBarPanel.OverflowGroup="Insert" controls:CommandBarPanel.CollapseOrder="1"
                        AutomationProperties.Name="Insert link"
                        Command="controls:MarkdownEditingCommands.InsertLink"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Insert link"
                                             Detail="Turn the selection into a link, or insert a new one." Gesture="Ctrl+K" />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.InsertLink}" />
                </Button>
                <Button Style="{StaticResource IconFormatButton}"
                        controls:CommandBarPanel.OverflowGroup="Insert" controls:CommandBarPanel.CollapseOrder="1"
                        AutomationProperties.Name="Insert image"
                        Command="controls:MarkdownEditingCommands.InsertImage"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Insert image"
                                             Detail="Insert an image from a file or web address." />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.InsertImage}" />
                </Button>
                <Button Style="{StaticResource IconFormatButton}"
                        controls:CommandBarPanel.OverflowGroup="Insert" controls:CommandBarPanel.CollapseOrder="1"
                        AutomationProperties.Name="Block quote"
                        Command="controls:MarkdownEditingCommands.ToggleBlockQuote"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Block quote"
                                             Detail="Quote the selected paragraphs, or unquote them." />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleBlockQuote}" />
                </Button>
                <Menu Style="{StaticResource CommandMenu}"
                      controls:CommandBarPanel.OverflowGroup="Insert" controls:CommandBarPanel.CollapseOrder="1">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              AutomationProperties.Name="Table">
                        <MenuItem.ToolTip>
                            <controls:CommandTip Heading="Table"
                                                 Detail="Insert a table, or add and remove rows and columns in the table at the cursor." />
                        </MenuItem.ToolTip>
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Table}" />
                        </MenuItem.Header>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Add Table"
                                  Command="controls:MarkdownEditingCommands.InsertTable"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Add table"
                                                     Detail="Insert a new three-column table at the cursor." />
                            </MenuItem.ToolTip>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Add Row"
                                  Command="controls:MarkdownEditingCommands.AddTableRow"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Add row"
                                                     Detail="Add a row below the cursor's row in the current table." />
                            </MenuItem.ToolTip>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Add Column"
                                  Command="controls:MarkdownEditingCommands.AddTableColumn"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Add column"
                                                     Detail="Add a column to the right of the cursor's column." />
                            </MenuItem.ToolTip>
                        </MenuItem>
                        <Separator />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Remove Row"
                                  Command="controls:MarkdownEditingCommands.RemoveTableRow"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Remove row"
                                                     Detail="Delete the cursor's row from the current table. A table always keeps its header row." />
                            </MenuItem.ToolTip>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Remove Column"
                                  Command="controls:MarkdownEditingCommands.RemoveTableColumn"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Remove column"
                                                     Detail="Delete the cursor's column from the current table. A table always keeps at least one column." />
                            </MenuItem.ToolTip>
                        </MenuItem>
                    </MenuItem>
                </Menu>
                <Button Style="{StaticResource IconFormatButton}"
                        controls:CommandBarPanel.OverflowGroup="Insert" controls:CommandBarPanel.CollapseOrder="1"
                        AutomationProperties.Name="Flowchart builder"
                        Command="controls:MarkdownEditingCommands.OpenFlowchartBuilder"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Flowchart builder"
                                             Detail="Build a Mermaid flowchart on a drag-and-drop canvas." Gesture="Ctrl+Shift+D" />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Flowchart}" />
                </Button>

                <!-- Insert group — collapsed form: one dropdown gathering the same insert actions, shown
                     only while the expanded icons above do not fit (INV-054). -->
                <Menu Style="{StaticResource CommandMenu}"
                      controls:CommandBarPanel.OverflowGroup="Insert" controls:CommandBarPanel.IsOverflow="True"
                      controls:CommandBarPanel.CollapseOrder="1">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              AutomationProperties.Name="Insert">
                        <MenuItem.ToolTip>
                            <controls:CommandTip Heading="Insert"
                                                 Detail="Insert a link, image, table, flowchart, or block quote." />
                        </MenuItem.ToolTip>
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Insert}" />
                        </MenuItem.Header>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Insert link"
                                  Command="controls:MarkdownEditingCommands.InsertLink"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Insert link"
                                                     Detail="Turn the selection into a link, or insert a new one." Gesture="Ctrl+K" />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.InsertLink}" />
                                    <TextBlock Text="Link  (Ctrl+K)" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Insert image"
                                  Command="controls:MarkdownEditingCommands.InsertImage"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Insert image"
                                                     Detail="Insert an image from a file or web address." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.InsertImage}" />
                                    <TextBlock Text="Image" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Block quote"
                                  Command="controls:MarkdownEditingCommands.ToggleBlockQuote"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Block quote"
                                                     Detail="Quote the selected paragraphs, or unquote them." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleBlockQuote}" />
                                    <TextBlock Text="Block quote" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Add Table"
                                  Command="controls:MarkdownEditingCommands.InsertTable"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Add table"
                                                     Detail="Insert a new three-column table at the cursor." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Table}" />
                                    <TextBlock Text="Table" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Add Row"
                                  Command="controls:MarkdownEditingCommands.AddTableRow"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Add row"
                                                     Detail="Add a row below the cursor's row in the current table." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Add row" Margin="32,0,0,0" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Add Column"
                                  Command="controls:MarkdownEditingCommands.AddTableColumn"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Add column"
                                                     Detail="Add a column to the right of the cursor's column." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Add column" Margin="32,0,0,0" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Remove Row"
                                  Command="controls:MarkdownEditingCommands.RemoveTableRow"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Remove row"
                                                     Detail="Delete the cursor's row from the current table. A table always keeps its header row." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Remove row" Margin="32,0,0,0" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Remove Column"
                                  Command="controls:MarkdownEditingCommands.RemoveTableColumn"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Remove column"
                                                     Detail="Delete the cursor's column from the current table. A table always keeps at least one column." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Remove column" Margin="32,0,0,0" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Flowchart builder"
                                  Command="controls:MarkdownEditingCommands.OpenFlowchartBuilder"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Flowchart builder"
                                                     Detail="Build a Mermaid flowchart on a drag-and-drop canvas." Gesture="Ctrl+Shift+D" />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Flowchart}" />
                                    <TextBlock Text="Flowchart…  (Ctrl+Shift+D)" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <Rectangle DockPanel.Dock="Left" Style="{StaticResource CommandSeparator}" />

                <!-- View group — expanded form: the panel toggles (highlighted while their panel is shown)
                     and the fold-all actions, shown while the row is wide enough. When it would overflow
                     they collapse to the View dropdown below (INV-054). CollapseOrder 0 collapses first. -->
                <Button controls:CommandBarPanel.OverflowGroup="View" controls:CommandBarPanel.CollapseOrder="0"
                        Command="{Binding Folder.ToggleFolderPanelCommand}"
                        AutomationProperties.Name="Toggle the folder panel">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Folder panel"
                                             Detail="Show or hide the folder browser." />
                    </Button.ToolTip>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconFormatButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Folder.IsFolderPanelVisible}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleFolderPanel}" />
                </Button>
                <Button controls:CommandBarPanel.OverflowGroup="View" controls:CommandBarPanel.CollapseOrder="0"
                        Command="{Binding SideDock.ToggleNavigationPanelCommand}"
                        AutomationProperties.Name="Toggle the navigation panel">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Navigation panel"
                                             Detail="Show or hide the document's outline (its headings)." />
                    </Button.ToolTip>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconFormatButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SideDock.IsNavigationPanelOpen}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleNavigationPanel}" />
                </Button>
                <Button controls:CommandBarPanel.OverflowGroup="View" controls:CommandBarPanel.CollapseOrder="0"
                        Command="{Binding ToggleSourcePanelCommand}"
                        AutomationProperties.Name="Toggle the raw Markdown source panel">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Source panel"
                                             Detail="Show or hide the raw Markdown source beside the editor." />
                    </Button.ToolTip>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconFormatButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSourcePanelOpen}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleSourcePanel}" />
                </Button>
                <Button controls:CommandBarPanel.OverflowGroup="View" controls:CommandBarPanel.CollapseOrder="0"
                        Command="{Binding TogglePreviewPanelCommand}"
                        AutomationProperties.Name="Toggle the diagram preview panel">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Diagram preview"
                                             Detail="Show or hide the live preview of the selected diagram." />
                    </Button.ToolTip>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconFormatButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewPanelOpen}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.TogglePreviewPanel}" />
                </Button>
                <Button controls:CommandBarPanel.OverflowGroup="View" controls:CommandBarPanel.CollapseOrder="0"
                        Command="{Binding ToggleEditorPaneCommand}"
                        AutomationProperties.Name="Toggle the editor pane">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Editor pane"
                                             Detail="Show or hide the WYSIWYG editor. The source panel must be docked before the editor can close." />
                    </Button.ToolTip>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconFormatButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditorPaneOpen}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleEditorPane}" />
                </Button>
                <Button controls:CommandBarPanel.OverflowGroup="View" controls:CommandBarPanel.CollapseOrder="0"
                        Command="{Binding TogglePageViewCommand}"
                        AutomationProperties.Name="Toggle page view">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Page view"
                                             Detail="Lay the document out on a fixed-width page, like a word processor." />
                    </Button.ToolTip>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconFormatButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPageViewEnabled}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.TogglePageView}" />
                </Button>
                <!-- Page Setup: the one editor-wide orientation and Print Margins, obeyed by the
                     Document Sheet, the Print Preview, and the printout alike (INV-061). Always a
                     dropdown (like the Export Menu), so it never joins the View group's overflow. -->
                <Menu DockPanel.Dock="Left" Style="{StaticResource CommandMenu}">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              AutomationProperties.Name="Page setup">
                        <MenuItem.ToolTip>
                            <controls:CommandTip Heading="Page setup"
                                                 Detail="Choose the page's orientation and print margins — on screen and in print alike." />
                        </MenuItem.ToolTip>
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.PageSetup}" />
                        </MenuItem.Header>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Portrait orientation"
                                  IsChecked="{Binding DataContext.PageSetup.Orientation, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=Portrait, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.SetPageOrientationCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  CommandParameter="{x:Static core:PageOrientation.Portrait}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Portrait"
                                                     Detail="The page upright: 8.5 × 11 inches." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Portrait" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Landscape orientation"
                                  IsChecked="{Binding DataContext.PageSetup.Orientation, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=Landscape, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.SetPageOrientationCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  CommandParameter="{x:Static core:PageOrientation.Landscape}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Landscape"
                                                     Detail="The page on its side: 11 × 8.5 inches." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Landscape" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator />
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Normal margins"
                                  IsChecked="{Binding DataContext.MarginPreset, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=Normal, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.SetMarginPresetCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  CommandParameter="{x:Static core:MarginPreset.Normal}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Normal margins"
                                                     Detail="One inch on every side." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Normal margins (1&quot;)" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Narrow margins"
                                  IsChecked="{Binding DataContext.MarginPreset, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=Narrow, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.SetMarginPresetCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  CommandParameter="{x:Static core:MarginPreset.Narrow}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Narrow margins"
                                                     Detail="Half an inch on every side." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Narrow margins (0.5&quot;)" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Moderate margins"
                                  IsChecked="{Binding DataContext.MarginPreset, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=Moderate, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.SetMarginPresetCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  CommandParameter="{x:Static core:MarginPreset.Moderate}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Moderate margins"
                                                     Detail="One inch top and bottom, three-quarters of an inch left and right." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Moderate margins" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Wide margins"
                                  IsChecked="{Binding DataContext.MarginPreset, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=Wide, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.SetMarginPresetCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  CommandParameter="{x:Static core:MarginPreset.Wide}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Wide margins"
                                                     Detail="One inch top and bottom, two inches left and right." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Wide margins" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Custom margins"
                                  IsChecked="{Binding DataContext.MarginPreset, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=Custom, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.EditCustomMarginsCommand, RelativeSource={RelativeSource AncestorType=Menu}}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Custom margins"
                                                     Detail="Enter the four margins yourself, in inches. Cancelling changes nothing." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <TextBlock Text="Custom margins…" VerticalAlignment="Center" />
                            </MenuItem.Header>
                        </MenuItem>
                    </MenuItem>
                </Menu>
                <Rectangle Style="{StaticResource CommandSeparator}"
                           controls:CommandBarPanel.OverflowGroup="View" controls:CommandBarPanel.CollapseOrder="0" />
                <Button Style="{StaticResource IconFormatButton}"
                        controls:CommandBarPanel.OverflowGroup="View" controls:CommandBarPanel.CollapseOrder="0"
                        AutomationProperties.Name="Collapse all sections"
                        Command="controls:MarkdownEditingCommands.CollapseAllFolds"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Collapse all sections"
                                             Detail="Fold every section so only its heading shows." />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.CollapseAllFolds}" />
                </Button>
                <Button Style="{StaticResource IconFormatButton}"
                        controls:CommandBarPanel.OverflowGroup="View" controls:CommandBarPanel.CollapseOrder="0"
                        AutomationProperties.Name="Expand all sections"
                        Command="controls:MarkdownEditingCommands.ExpandAllFolds"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Expand all sections"
                                             Detail="Unfold every folded section." Gesture="Ctrl+Shift+M" />
                    </Button.ToolTip>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ExpandAllFolds}" />
                </Button>

                <!-- View group — collapsed form: one dropdown gathering the same panel toggles (checked
                     while shown) and fold actions, shown only while the expanded icons do not fit (INV-054). -->
                <Menu Style="{StaticResource CommandMenu}"
                      controls:CommandBarPanel.OverflowGroup="View" controls:CommandBarPanel.IsOverflow="True"
                      controls:CommandBarPanel.CollapseOrder="0">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              AutomationProperties.Name="View">
                        <MenuItem.ToolTip>
                            <controls:CommandTip Heading="View"
                                                 Detail="Show or hide the panels, and fold or unfold all sections." />
                        </MenuItem.ToolTip>
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.View}" />
                        </MenuItem.Header>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Toggle the folder panel"
                                  IsChecked="{Binding DataContext.Folder.IsFolderPanelVisible, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.Folder.ToggleFolderPanelCommand, RelativeSource={RelativeSource AncestorType=Menu}}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Folder panel"
                                                     Detail="Show or hide the folder browser." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleFolderPanel}" />
                                    <TextBlock Text="Folder panel" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Toggle the navigation panel"
                                  IsChecked="{Binding DataContext.SideDock.IsNavigationPanelOpen, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.SideDock.ToggleNavigationPanelCommand, RelativeSource={RelativeSource AncestorType=Menu}}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Navigation panel"
                                                     Detail="Show or hide the document's outline (its headings)." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleNavigationPanel}" />
                                    <TextBlock Text="Navigation panel" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Toggle the raw Markdown source panel"
                                  IsChecked="{Binding DataContext.IsSourcePanelOpen, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.ToggleSourcePanelCommand, RelativeSource={RelativeSource AncestorType=Menu}}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Source panel"
                                                     Detail="Show or hide the raw Markdown source beside the editor." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleSourcePanel}" />
                                    <TextBlock Text="Source panel" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Toggle the diagram preview panel"
                                  IsChecked="{Binding DataContext.IsPreviewPanelOpen, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.TogglePreviewPanelCommand, RelativeSource={RelativeSource AncestorType=Menu}}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Diagram preview"
                                                     Detail="Show or hide the live preview of the selected diagram." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.TogglePreviewPanel}" />
                                    <TextBlock Text="Preview panel" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuToggleEntry}" AutomationProperties.Name="Toggle the editor pane"
                                  IsChecked="{Binding DataContext.IsEditorPaneOpen, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Menu}}"
                                  Command="{Binding DataContext.ToggleEditorPaneCommand, RelativeSource={RelativeSource AncestorType=Menu}}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Editor pane"
                                                     Detail="Show or hide the WYSIWYG editor. The source panel must be docked before the editor can close." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleEditorPane}" />
                                    <TextBlock Text="Editor pane" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Collapse all sections"
                                  Command="controls:MarkdownEditingCommands.CollapseAllFolds"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Collapse all sections"
                                                     Detail="Fold every section so only its heading shows." />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.CollapseAllFolds}" />
                                    <TextBlock Text="Collapse all sections" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" AutomationProperties.Name="Expand all sections"
                                  Command="controls:MarkdownEditingCommands.ExpandAllFolds"
                                  CommandTarget="{Binding ElementName=Editor}">
                            <MenuItem.ToolTip>
                                <controls:CommandTip Heading="Expand all sections"
                                                     Detail="Unfold every folded section." Gesture="Ctrl+Shift+M" />
                            </MenuItem.ToolTip>
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ExpandAllFolds}" />
                                    <TextBlock Text="Expand all sections  (Ctrl+Shift+M)" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <!-- Theme toggle: shows the theme you'd switch to. -->
                <Button DockPanel.Dock="Right" Style="{StaticResource IconCommandButton}"
                        Command="{Binding Appearance.ToggleThemeCommand}"
                        AutomationProperties.Name="Toggle light or dark theme">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="Theme"
                                             Detail="Switch between the light and dark theme." />
                    </Button.ToolTip>
                    <Path>
                        <Path.Style>
                            <Style TargetType="Path" BasedOn="{StaticResource CommandIcon}">
                                <Setter Property="Data" Value="{StaticResource Icon.ThemeDark}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Appearance.IsDarkTheme}" Value="True">
                                        <Setter Property="Data" Value="{StaticResource Icon.ThemeLight}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Button>
            </controls:CommandBarPanel>
        </Border>

        <!-- Tab strip: one Tab per open Editor Session, plus a new-tab button. -->
        <Border Grid.Row="1" Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Content="+"
                        FontSize="18" Margin="4,4,8,4" Command="{Binding NewCommand}">
                    <Button.ToolTip>
                        <controls:CommandTip Heading="New document"
                                             Detail="Start a new, empty document in a new tab." Gesture="Ctrl+N" />
                    </Button.ToolTip>
                </Button>
                <ListBox Style="{StaticResource TabStrip}" ItemContainerStyle="{StaticResource TabItem}"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding ActiveSession, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center"
                                         Fill="{DynamicResource DirtyDotBrush}"
                                         Visibility="{Binding HasUnsavedEdits, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                <Button Style="{StaticResource TabCloseButton}" Content="&#x2715;"
                                        Command="{Binding DataContext.CloseSessionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}">
                                    <Button.ToolTip>
                                        <controls:CommandTip Heading="Close tab"
                                                             Detail="Close this document. You'll be asked before losing any unsaved edits." Gesture="Ctrl+W" />
                                    </Button.ToolTip>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Conflict banner for the Active Session: the Watched File changed on disk while there were
             unsaved edits. Neither side is discarded without an explicit choice (INV-006). -->
        <Border Grid.Row="2" Background="{DynamicResource ConflictBackgroundBrush}"
                BorderBrush="{DynamicResource ConflictBorderBrush}" BorderThickness="0,0,0,1" Padding="14,9"
                Visibility="{Binding ActiveSession.HasConflict, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <!-- View Difference: informational, so it precedes the two resolving choices. It
                         toggles the Difference Overlay and resolves nothing itself (INV-021). The
                         Content is set through the Style so the DataTrigger can swap it. -->
                    <Button Command="{Binding ActiveSession.ViewDifferenceCommand}" Margin="4,0">
                        <Button.ToolTip>
                            <controls:CommandTip Heading="View difference"
                                                 Detail="Compare your unsaved edits with the version on disk." />
                        </Button.ToolTip>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CommandButton}">
                                <Setter Property="Content" Value="View difference" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSession.IsDifferenceVisible}" Value="True">
                                        <Setter Property="Content" Value="Hide difference" />
                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Keep my edits" Style="{StaticResource CommandButton}"
                            Command="{Binding ActiveSession.KeepMyEditsCommand}" Margin="4,0">
                        <Button.ToolTip>
                            <controls:CommandTip Heading="Keep my edits"
                                                 Detail="Keep your unsaved edits and ignore the change made on disk." />
                        </Button.ToolTip>
                    </Button>
                    <Button Content="Reload from disk" Style="{StaticResource CommandButton}"
                            Command="{Binding ActiveSession.ReloadFromDiskCommand}" Margin="4,0">
                        <Button.ToolTip>
                            <controls:CommandTip Heading="Reload from disk"
                                                 Detail="Discard your unsaved edits and load the file's version from disk." />
                        </Button.ToolTip>
                    </Button>
                </StackPanel>
                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap"
                           Foreground="{DynamicResource ConflictTextBrush}"
                           Text="This file was changed on disk while you had unsaved edits. Keep your edits or reload the file?" />
            </DockPanel>
        </Border>

        <!-- Editing area. Shows the WYSIWYG surface (with the Editor Gutter and the toggleable
             Navigation Panel) while a Tab is open, or the Empty-Workspace Placeholder when every Tab
             has been closed (INV-008). -->
        <Grid Grid.Row="3"
              controls:SizeObserver.Observe="True"
              controls:SizeObserver.ObservedWidth="{Binding WorkspaceWidth, Mode=OneWayToSource}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left Auto-Hide Bar: one tab per Auto-Hidden left panel — Editor Pane, Folder Panel,
                 Navigation Panel — shown only while it has tabs. Activating a tab opens that panel's
                 Panel Flyout over the editing area (INV-062). -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                    Visibility="{Binding HasLeftAutoHideTabs, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding LeftAutoHideTabs}" Focusable="False" Margin="2,10,2,0"
                              ItemTemplate="{StaticResource AutoHideTabButton}" />
            </Border>

            <!-- Side Dock: the outer-left, workspace-wide panel that hosts the Folder Panel and the
                 Navigation Panel as tabs (INV-046), so the two need not each take a column. It is not
                 gated on an Active Session — the Folder tab stays browsable even when every Tab has been
                 closed (INV-043) — and is shown while at least one of its tabs is Docked (INV-046), or
                 as the Panel Flyout of an Auto-Hidden Folder or Navigation Panel, overhanging the
                 editing area (INV-062). -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="Width" Value="260" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SideDock.IsVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <!-- Flyout mode: the dock presents the Auto-Hidden panel over the editing
                                 area — wider, above everything, and dismissed without a layout change. -->
                            <DataTrigger Binding="{Binding IsSideDockFlyoutOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                                <Setter Property="Grid.ColumnSpan" Value="2" />
                                <Setter Property="Panel.ZIndex" Value="40" />
                                <Setter Property="HorizontalAlignment" Value="Left" />
                                <Setter Property="Width" Value="300" />
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="16" ShadowDepth="3" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <!-- Tab strip: one header per Docked panel, the Selected one highlighted, with the
                         presented panel's Pin Toggle and Close Button at the right (INV-062). -->
                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel Margin="6,6,6,0" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource IconButton}"
                                        Command="{Binding TogglePinCommand}"
                                        CommandParameter="{Binding DisplayedSideDockPanel}"
                                        AutomationProperties.Name="Pin or unpin panel">
                                    <Button.ToolTip>
                                        <controls:CommandTip Heading="Pin"
                                                             Detail="Unpin the panel to slide it away to the window's edge; pin it to dock it in place again." />
                                    </Button.ToolTip>
                                    <Path Width="13" Height="13" Stretch="Uniform" Fill="{x:Null}"
                                          Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="1.8"
                                          StrokeLineJoin="Round">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Data" Value="{StaticResource Icon.Pin}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSideDockPanelPinned}" Value="False">
                                                        <Setter Property="Data" Value="{StaticResource Icon.PinOff}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Button>
                                <Button Style="{StaticResource IconButton}"
                                        Command="{Binding ClosePanelCommand}"
                                        CommandParameter="{Binding DisplayedSideDockPanel}"
                                        AutomationProperties.Name="Close panel">
                                    <Button.ToolTip>
                                        <controls:CommandTip Heading="Close"
                                                             Detail="Close this panel. Reopen it any time from the command bar's view controls." />
                                    </Button.ToolTip>
                                    <Path Width="11" Height="11" Stretch="Uniform" Fill="{x:Null}"
                                          Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="1.8"
                                          StrokeLineJoin="Round" Data="{StaticResource Icon.Close}" />
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding SideDock.SelectFolderTabCommand}"
                                    Visibility="{Binding SideDock.IsFolderTabVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    AutomationProperties.Name="Folder tab">
                                <Button.ToolTip>
                                    <controls:CommandTip Heading="Folder"
                                                         Detail="Show the open folder's Markdown files." />
                                </Button.ToolTip>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource CommandButton}">
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                        <Setter Property="Padding" Value="9,5" />
                                        <Setter Property="Margin" Value="0,0,4,0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SideDock.SelectedTab}" Value="Folder">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="15" Height="15" Stretch="Uniform" Fill="{x:Null}"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="2" StrokeLineJoin="Round" Data="{StaticResource Icon.Folder}" />
                                    <TextBlock Text="Folder" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SideDock.SelectNavigationTabCommand}"
                                    Visibility="{Binding SideDock.IsNavigationTabVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    AutomationProperties.Name="Outline tab">
                                <Button.ToolTip>
                                    <controls:CommandTip Heading="Outline"
                                                         Detail="Show the list of the document's headings." />
                                </Button.ToolTip>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource CommandButton}">
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                        <Setter Property="Padding" Value="9,5" />
                                        <Setter Property="Margin" Value="0,0,4,0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SideDock.SelectedTab}" Value="Navigation">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="15" Height="15" Stretch="Uniform" Fill="{x:Null}"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="2" StrokeLineJoin="Round" Data="{StaticResource Icon.ToggleNavigationPanel}" />
                                    <TextBlock Text="Outline" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Content: the presented tab's panel — the Selected tab, or the panel whose
                         Panel Flyout is open (only one is shown at a time; INV-046, INV-062). -->
                    <Grid>
                        <!-- Folder tab: the Folder Tree, or a prompt to open a folder. -->
                        <DockPanel>
                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SideDockDisplayedTab}" Value="Folder">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>
                            <Grid DockPanel.Dock="Top">
                                <TextBlock Text="{Binding Folder.Folder.Name, TargetNullValue='FOLDER'}"
                                           Margin="14,10,10,6" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" />
                                <Button HorizontalAlignment="Right" Margin="0,2,8,0" Style="{StaticResource IconButton}"
                                        Command="{Binding Folder.RefreshCommand}"
                                        Visibility="{Binding Folder.HasFolder, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        AutomationProperties.Name="Refresh the folder">
                                    <Button.ToolTip>
                                        <controls:CommandTip Heading="Refresh"
                                                             Detail="Rescan the open folder for added, removed, or renamed files." />
                                    </Button.ToolTip>
                                    <Path Width="14" Height="14" Stretch="Uniform" Fill="{x:Null}"
                                          Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="2"
                                          StrokeLineJoin="Round" Data="{StaticResource Icon.Refresh}" />
                                </Button>
                            </Grid>
                            <Grid>
                                <controls:FolderPanel Workspace="{Binding Folder.Folder}"
                                                      ActivateCommand="{Binding Folder.ActivateEntryCommand}"
                                                      AutomationProperties.AutomationId="FolderTree"
                                                      Visibility="{Binding Folder.HasFolder, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="14">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Folder.HasFolder}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="No folder open" HorizontalAlignment="Center" Margin="0,0,0,8"
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                                    <Button Content="Open folder" Style="{StaticResource CommandButton}"
                                            HorizontalAlignment="Center" Command="{Binding Folder.OpenFolderCommand}" />
                                </StackPanel>
                            </Grid>
                        </DockPanel>

                        <!-- Outline tab: the Active Session's Outline, or a hint when no document is open. -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SideDockDisplayedTab}" Value="Navigation">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <controls:OutlinePanel Editor="{Binding ElementName=Editor}"
                                                   AutomationProperties.AutomationId="OutlineList"
                                                   Visibility="{Binding HasOpenSessions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock Text="No document open" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Margin="14" TextAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" FontSize="12"
                                       Visibility="{Binding IsWorkspaceEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- The editing area proper (editor, placeholder, Find Bar, Difference Overlay). -->
            <Grid Grid.Column="2">

            <!-- The WYSIWYG editing surface, bound to the Active Session, with the Editor Gutter (line
                 numbers + fold chevrons) alongside it and the toggleable Source Panel (raw Markdown
                 source) split to its right. The Outline (Navigation Panel) lives in the Side Dock to the
                 left of this grid, not inside it. -->
            <Grid Visibility="{Binding HasOpenSessions, Converter={StaticResource BooleanToVisibilityConverter}}">
                <!-- Each toggleable panel is a Panel Column: PanelColumn owns its width, so a Panel
                     Splitter drag and the View-menu toggle cannot fight over it, and a hidden panel
                     gives up every pixel to the Visual Document (INV-056). The editing area keeps a
                     minimum width so no drag can crush it away. -->
                <Grid.ColumnDefinitions>
                    <!-- The Editor Pane's column is a fill Panel Column: shown it takes the remaining
                         width at the editor's minimum, hidden (Closed or Auto-Hidden) it takes none —
                         and the Source Panel's column fills in its stead while it is the primary
                         Document Pane (INV-056, INV-062, INV-063). -->
                    <ColumnDefinition controls:PanelColumn.Fill="True"
                                     controls:PanelColumn.MinimumWidth="240"
                                     controls:PanelColumn.IsVisible="{Binding IsEditorPaneVisible}" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition controls:PanelColumn.VisibleWidth="420"
                                     controls:PanelColumn.Fill="{Binding IsSourcePanelPrimary}"
                                     controls:PanelColumn.IsVisible="{Binding IsSourcePanelVisible}" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition controls:PanelColumn.VisibleWidth="420"
                                     controls:PanelColumn.IsVisible="{Binding IsPreviewPanelVisible}" />
                </Grid.ColumnDefinitions>

                <!-- Editor Pane: the Panel Header (pin, close — INV-062) over the editor canvas: the
                     Editor Gutter and the WYSIWYG surface, hosted in a ScrollViewer so Page View can
                     float the fixed-width Document Sheet on it and scroll the whole page as one piece
                     (INV-058). In plain (non-page) mode the ScrollViewer does not scroll — the editor
                     fills the pane and scrolls itself, exactly as before; PageView switches the two.
                     While Auto-Hidden the pane collapses with its column and reappears as a full-width
                     Panel Flyout from the left Auto-Hide Bar (INV-062). -->
                <Border Grid.Column="0" Background="{DynamicResource EditorBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditorPaneVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsEditorPaneFlyoutOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Grid.ColumnSpan" Value="5" />
                                    <Setter Property="Panel.ZIndex" Value="30" />
                                    <Setter Property="BorderThickness" Value="0,0,1,0" />
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="16" ShadowDepth="3" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel>
                        <controls:PanelHeader DockPanel.Dock="Top" Title="EDITOR"
                                              IsPinned="{Binding IsEditorPanePinned}"
                                              PinCommand="{Binding TogglePinCommand}"
                                              CloseCommand="{Binding ClosePanelCommand}"
                                              CommandParameter="{x:Static viewModels:DockablePanel.EditorPane}" />
                <ScrollViewer x:Name="EditorScroller" Focusable="False"
                              AutomationProperties.AutomationId="EditorCanvas"
                              VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
                    <Grid controls:PageView.IsEnabled="{Binding IsPageViewEnabled}"
                          controls:PageView.Editor="{Binding ElementName=Editor}"
                          controls:PageView.Canvas="{Binding ElementName=EditorScroller}"
                          controls:PageView.Source="{Binding ElementName=SourcePanel}"
                          controls:PageView.Setup="{Binding PageSetup}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <controls:EditorGutter Grid.Column="0" Editor="{Binding ElementName=Editor}" />

                        <!-- The Document Sheet's paper and the Page Break rule where each Page ends,
                             drawn behind the editing surface (which Page View makes transparent) so a
                             break passes under the text rather than striking through it. Sized to the
                             editor, which Page View grows in whole Pages, at the Page Setup's oriented
                             page height (INV-058, INV-061). -->
                        <controls:DocumentSheetBackdrop Grid.Column="1"
                                                        HorizontalAlignment="Left" VerticalAlignment="Top"
                                                        Width="{Binding ActualWidth, ElementName=Editor}"
                                                        Height="{Binding ActualHeight, ElementName=Editor}"
                                                        PageHeight="{Binding PageSetup.PageHeight}"
                                                        Visibility="{Binding IsPageViewEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <controls:MarkdownRichEditor x:Name="Editor" Grid.Column="1"
                                                     Markdown="{Binding ActiveSession.Markdown, UpdateSourceTrigger=PropertyChanged}"
                                                     ChangedRegions="{Binding ActiveSession.ChangeHighlight}"
                                                     BaseDirectory="{Binding ActiveSession.BaseDirectory}"
                                                     LinkPrompt="{Binding LinkPrompt}"
                                                     FlowchartBuilder="{Binding FlowchartBuilder}"
                                                     DiagramImageRenderer="{Binding DiagramImageRenderer}"
                                                     IsDarkTheme="{Binding Appearance.IsDarkTheme}"
                                                     DocumentPrinter="{Binding DocumentPrinter}"
                                                     PrintPreview="{Binding PrintPreview}"
                                                     PageSetup="{Binding PageSetup}"
                                                     Renderer="{Binding Renderer}"
                                                     FollowLinkCommand="{Binding FollowLinkCommand}"
                                                     controls:ScrollSync.SyncPartner="{Binding ElementName=SourcePanel}" />
                    </Grid>
                </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Splitter between the Visual Document and the Source Panel. Hidden with the panel,
                     and while the Source Panel is the primary Document Pane with no editor beside it
                     (INV-063). -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns" Background="{DynamicResource BorderBrush}"
                              Visibility="{Binding IsSourceSplitterVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- Source Panel: the Active Session's raw, editable Markdown source, two-way bound to
                     the same canonical Markdown as the Visual Document so the two stay in sync
                     (INV-013). It is the one surface that shows Markdown syntax. Hidden until toggled
                     on (INV-014); while Auto-Hidden it reappears as a Panel Flyout from the right
                     Auto-Hide Bar (INV-062). -->
                <Border Background="{DynamicResource EditorBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Grid.Column" Value="2" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSourcePanelVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSourcePanelFlyoutOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Grid.Column" Value="0" />
                                    <Setter Property="Grid.ColumnSpan" Value="5" />
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Width" Value="420" />
                                    <Setter Property="Panel.ZIndex" Value="30" />
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="16" ShadowDepth="3" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel>
                        <controls:PanelHeader DockPanel.Dock="Top" Title="SOURCE"
                                              IsPinned="{Binding IsSourcePanelPinned}"
                                              PinCommand="{Binding TogglePinCommand}"
                                              CloseCommand="{Binding ClosePanelCommand}"
                                              CommandParameter="{x:Static viewModels:DockablePanel.SourcePanel}" />
                        <!-- The Source Gutter (Line Numbers) mirrors the source TextBox's line layout.
                             The TextBox does not wrap, so each source line is a single row aligned to
                             its Line Number. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <controls:SourceGutter Grid.Column="0" Source="{Binding ElementName=SourcePanel}" />
                            <!-- Delay debounces the source→Visual-Document projection: keystrokes coalesce
                                 so a full re-Project runs once typing pauses, not on every key. The TextBox
                                 (the binding target) stays instantly responsive. -->
                            <TextBox Grid.Column="1" x:Name="SourcePanel"
                                     AutomationProperties.AutomationId="SourcePanel"
                                     Text="{Binding ActiveSession.Markdown, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                                     controls:ScrollSync.SyncPartner="{Binding ElementName=Editor}"
                                     AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                     FontFamily="Cascadia Code, Consolas, monospace" FontSize="13"
                                     Background="Transparent" BorderThickness="0" Padding="6,4,12,12"
                                     Foreground="{DynamicResource TextBrush}"
                                     CaretBrush="{DynamicResource TextBrush}"
                                     SpellCheck.IsEnabled="True" />
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Splitter between the Source Panel (or the Visual Document) and the Preview Panel.
                     Hidden with the panel. -->
                <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns" Background="{DynamicResource BorderBrush}"
                              Visibility="{Binding IsPreviewPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- Preview Panel: the live Diagram Preview of the Mermaid Diagram at the caret,
                     rendered by the bundled Mermaid library in a WebView2. Presentation-only and hidden
                     until toggled on (INV-047, INV-048); it follows the app light/dark theme. While
                     Auto-Hidden it reappears as a Panel Flyout from the right Auto-Hide Bar (INV-062). -->
                <Border Background="{DynamicResource EditorBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Grid.Column" Value="4" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewPanelVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsPreviewPanelFlyoutOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Grid.Column" Value="0" />
                                    <Setter Property="Grid.ColumnSpan" Value="5" />
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Width" Value="420" />
                                    <Setter Property="Panel.ZIndex" Value="30" />
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="16" ShadowDepth="3" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel>
                        <controls:PanelHeader DockPanel.Dock="Top" Title="DIAGRAM PREVIEW"
                                              IsPinned="{Binding IsPreviewPanelPinned}"
                                              PinCommand="{Binding TogglePinCommand}"
                                              CloseCommand="{Binding ClosePanelCommand}"
                                              CommandParameter="{x:Static viewModels:DockablePanel.PreviewPanel}" />
                        <controls:MermaidPreview AutomationProperties.AutomationId="DiagramPreview"
                                                 DiagramSource="{Binding CurrentDiagramSource, ElementName=Editor}"
                                                 IsDark="{Binding Appearance.IsDarkTheme}" />
                    </DockPanel>
                </Border>

                <!-- Flyout backdrop: a click anywhere in the editing area outside the open Panel
                     Flyout dismisses it — dismissal is presentation-only (INV-062). Sits above the
                     docked panels (ZIndex 20) and below every flyout (ZIndex 30+). -->
                <Border Grid.Column="0" Grid.ColumnSpan="5" Panel.ZIndex="20" Background="Transparent"
                        Visibility="{Binding HasOpenFlyout, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding DismissFlyoutCommand}" />
                    </Border.InputBindings>
                </Border>
            </Grid>

            <!-- Empty-Workspace Placeholder: shown when no Tab is open. -->
            <Border Background="{DynamicResource EditorBackgroundBrush}"
                    Visibility="{Binding IsWorkspaceEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="No document open" FontSize="16" HorizontalAlignment="Center"
                               Margin="0,0,0,6" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="Press + to start a new document, or Open a file"
                               FontSize="12" HorizontalAlignment="Center"
                               Foreground="{DynamicResource MutedTextBrush}" />
                </StackPanel>
            </Border>

            <!-- Find Bar: floats over the editor's top-right, bound to the editor's Find state. Opened
                 with Ctrl+F (which focuses the query box) or Ctrl+H (which also shows the Replace
                 Row), dismissed with Escape. The Find row is view-only — finding never changes the
                 Markdown Document (INV-016) — while the Replace Row's two commands are real edits
                 that Capture back into it (INV-022). -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,26,0"
                    Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="8,5"
                    Visibility="{Binding IsFindActive, ElementName=Editor, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="12" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="FindQueryBox" Width="220" Style="{StaticResource FindBarTextBox}"
                                 controls:Watermark.Text="Find"
                                 controls:FocusOnVisible.Enabled="True"
                                 Text="{Binding FindQuery, ElementName=Editor, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="controls:MarkdownEditingCommands.FindNext"
                                            CommandTarget="{Binding ElementName=Editor}" />
                                <KeyBinding Key="Enter" Modifiers="Shift"
                                            Command="controls:MarkdownEditingCommands.FindPrevious"
                                            CommandTarget="{Binding ElementName=Editor}" />
                                <KeyBinding Key="Esc" Command="controls:MarkdownEditingCommands.HideFind"
                                            CommandTarget="{Binding ElementName=Editor}" />
                            </TextBox.InputBindings>
                        </TextBox>

                        <TextBlock Text="{Binding MatchSummary, ElementName=Editor}" MinWidth="56"
                                   VerticalAlignment="Center" TextAlignment="Right" Margin="8,0"
                                   FontSize="12" Foreground="{DynamicResource MutedTextBrush}" />

                        <Rectangle Style="{StaticResource CommandSeparator}" />

                        <Button Style="{StaticResource IconButton}" Content="&#x2191;" FontSize="13"
                                Command="controls:MarkdownEditingCommands.FindPrevious"
                                CommandTarget="{Binding ElementName=Editor}">
                            <Button.ToolTip>
                                <controls:CommandTip Heading="Previous match"
                                                     Detail="Select the previous match." Gesture="Shift+Enter" />
                            </Button.ToolTip>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Content="&#x2193;" FontSize="13"
                                Command="controls:MarkdownEditingCommands.FindNext"
                                CommandTarget="{Binding ElementName=Editor}">
                            <Button.ToolTip>
                                <controls:CommandTip Heading="Next match"
                                                     Detail="Select the next match." Gesture="Enter" />
                            </Button.ToolTip>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Content="&#x2715;" FontSize="12"
                                Command="controls:MarkdownEditingCommands.HideFind"
                                CommandTarget="{Binding ElementName=Editor}">
                            <Button.ToolTip>
                                <controls:CommandTip Heading="Close"
                                                     Detail="Close the find bar." Gesture="Esc" />
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>

                    <!-- Replace Row: shown only when the Find Bar was opened for Replace (Ctrl+H),
                         divided from the Find row above it. -->
                    <StackPanel Visibility="{Binding IsReplaceActive, ElementName=Editor, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Rectangle Style="{StaticResource PanelSeparator}" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="ReplacementBox" Width="220" Style="{StaticResource FindBarTextBox}"
                                     controls:Watermark.Text="Replace"
                                     Text="{Binding Replacement, ElementName=Editor, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="controls:MarkdownEditingCommands.Replace"
                                                CommandTarget="{Binding ElementName=Editor}" />
                                    <KeyBinding Key="Esc" Command="controls:MarkdownEditingCommands.HideFind"
                                                CommandTarget="{Binding ElementName=Editor}" />
                                </TextBox.InputBindings>
                            </TextBox>

                            <Button Style="{StaticResource FindBarButton}" Content="Replace" Margin="8,0,0,0"
                                    Command="controls:MarkdownEditingCommands.Replace"
                                    CommandTarget="{Binding ElementName=Editor}">
                                <Button.ToolTip>
                                    <controls:CommandTip Heading="Replace"
                                                         Detail="Replace the current match and move to the next." Gesture="Enter" />
                                </Button.ToolTip>
                            </Button>
                            <Button Style="{StaticResource FindBarButton}" Content="Replace all"
                                    Command="controls:MarkdownEditingCommands.ReplaceAll"
                                    CommandTarget="{Binding ElementName=Editor}">
                                <Button.ToolTip>
                                    <controls:CommandTip Heading="Replace all"
                                                         Detail="Replace every match, including any inside collapsed sections." />
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Difference Overlay: the Active Session's Conflict Difference, covering the whole
                 editing area (the Source Panel included — it edits the same Markdown, so leaving it
                 live beneath an open comparison would invite edits against the view) while the
                 Conflict bar above stays visible. Last child = topmost. View-only: computing,
                 showing, or hiding it never changes the Markdown Document, the Watched File, or the
                 Conflict (INV-021). -->
            <Border Background="{DynamicResource EditorBackgroundBrush}"
                    Visibility="{Binding ActiveSession.IsDifferenceVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="14,12,14,6" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="DIFFERENCE &#x2014; YOUR UNSAVED EDITS (&#x2212;) VS THE FILE ON DISK (+)" />
                    <!-- The ScrollViewer lives inside the template so the VirtualizingStackPanel gets a
                         real viewport; an outer ScrollViewer would give it infinite height and defeat
                         virtualisation on a long document. -->
                    <ItemsControl ItemsSource="{Binding ActiveSession.DifferenceLines}" Focusable="False"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer Focusable="False" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="LineRoot" Padding="14,1">
                                    <DockPanel>
                                        <TextBlock x:Name="Marker" DockPanel.Dock="Left" Width="16" Text=" "
                                                   FontFamily="Cascadia Code, Consolas, monospace" FontSize="13"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Text}" FontSize="13"
                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                   Foreground="{DynamicResource TextBrush}" />
                                    </DockPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Kind}" Value="SessionOnly">
                                        <Setter TargetName="LineRoot" Property="Background"
                                                Value="{DynamicResource DifferenceRemovedBrush}" />
                                        <Setter TargetName="Marker" Property="Text" Value="&#x2212;" />
                                        <Setter TargetName="Marker" Property="Foreground"
                                                Value="{DynamicResource DifferenceRemovedTextBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Kind}" Value="DiskOnly">
                                        <Setter TargetName="LineRoot" Property="Background"
                                                Value="{DynamicResource DifferenceAddedBrush}" />
                                        <Setter TargetName="Marker" Property="Text" Value="+" />
                                        <Setter TargetName="Marker" Property="Foreground"
                                                Value="{DynamicResource DifferenceAddedTextBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
            </Grid>

            <!-- Right Auto-Hide Bar: one tab per Auto-Hidden right panel — Source Panel, Preview
                 Panel — shown only while it has tabs (INV-062). -->
            <Border Grid.Column="3" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Visibility="{Binding HasRightAutoHideTabs, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding RightAutoHideTabs}" Focusable="False" Margin="2,10,2,0"
                              ItemTemplate="{StaticResource AutoHideTabButton}" />
            </Border>
        </Grid>

        <!-- Slim status bar: the Watched File path and an unsaved-changes hint. -->
        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,4">
            <DockPanel Visibility="{Binding HasOpenSessions, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource StatusText}" Text="Unsaved changes"
                           Margin="12,0,0,0"
                           Visibility="{Binding ActiveSession.HasUnsavedEdits, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- Document statistics and caret position, from the editor's live status (INV-039). -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource StatusText}" Margin="16,0,0,0"
                               Text="{Binding Status.CurrentSection, ElementName=Editor}" />
                    <TextBlock Style="{StaticResource StatusText}" Margin="16,0,0,0"
                               Text="{Binding Status.CaretLine, ElementName=Editor, StringFormat='Ln {0}'}" />
                    <TextBlock Style="{StaticResource StatusText}" Margin="6,0,0,0"
                               Text="{Binding Status.CaretColumn, ElementName=Editor, StringFormat='Col {0}'}" />
                    <TextBlock Style="{StaticResource StatusText}" Margin="16,0,0,0"
                               Text="{Binding Status.ReadingTimeText, ElementName=Editor}" />
                    <TextBlock Style="{StaticResource StatusText}" Margin="16,0,0,0"
                               Text="{Binding Status.WordCount, ElementName=Editor, StringFormat='{}{0} words'}" />
                    <TextBlock Style="{StaticResource StatusText}" Margin="6,0,0,0"
                               Text="{Binding Status.CharacterCount, ElementName=Editor, StringFormat='{}{0} chars'}" />
                </StackPanel>

                <TextBlock Style="{StaticResource StatusText}"
                           Text="{Binding ActiveSession.FilePath, TargetNullValue='Unsaved document'}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
