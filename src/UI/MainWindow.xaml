<Window x:Class="UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:UI.Controls"
        mc:Ignorable="d"
        Title="{Binding ActiveSession.Title, StringFormat='{}{0} — LiveMarkDownEditor', FallbackValue='LiveMarkDownEditor'}"
        Icon="pack://application:,,,/Assets/app.ico"
        Height="680" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        TextOptions.TextFormattingMode="Ideal">

    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="N" Command="{Binding NewCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="O" Command="{Binding OpenCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="W" Command="{Binding CloseSessionCommand}"
                    CommandParameter="{Binding ActiveSession}" />
        <KeyBinding Modifiers="Ctrl" Key="P" Command="controls:MarkdownEditingCommands.Print"
                    CommandTarget="{Binding ElementName=Editor}" />
        <KeyBinding Modifiers="Ctrl" Key="F" Command="controls:MarkdownEditingCommands.ShowFind"
                    CommandTarget="{Binding ElementName=Editor}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Single command bar: file actions, formatting, and the theme toggle. -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="8,6">
                <Button DockPanel.Dock="Left" Style="{StaticResource IconCommandButton}"
                        Command="{Binding NewCommand}" ToolTip="New document (Ctrl+N)"
                        AutomationProperties.Name="New document">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.New}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconCommandButton}"
                        Command="{Binding OpenCommand}" ToolTip="Open a Markdown file (Ctrl+O)"
                        AutomationProperties.Name="Open a Markdown file">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Open}" />
                </Button>

                <!-- Open Recent: the recently opened or saved files, newest first (INV-037). -->
                <Menu DockPanel.Dock="Left" Style="{StaticResource CommandMenu}">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              ToolTip="Open a recent file" AutomationProperties.Name="Open recent"
                              ItemsSource="{Binding RecentFiles}">
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.OpenRecent}" />
                        </MenuItem.Header>
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem" BasedOn="{StaticResource CommandMenuEntry}">
                                <Setter Property="Header" Value="{Binding}" />
                                <Setter Property="Command"
                                        Value="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=Menu}}" />
                                <Setter Property="CommandParameter" Value="{Binding}" />
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                </Menu>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconCommandButton}"
                        Command="{Binding SaveCommand}" ToolTip="Save (Ctrl+S)"
                        AutomationProperties.Name="Save">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Save}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconCommandButton}"
                        Command="{Binding Export.ExportHtmlCommand}" CommandParameter="{Binding ActiveSession}"
                        ToolTip="Export as HTML — write the rendered document to an .html file"
                        AutomationProperties.Name="Export as HTML">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ExportHtml}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconCommandButton}"
                        Command="{Binding Export.ExportPdfCommand}" CommandParameter="{Binding ActiveSession}"
                        ToolTip="Export as PDF — write the document to a .pdf file"
                        AutomationProperties.Name="Export as PDF">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ExportPdf}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconCommandButton}"
                        Command="controls:MarkdownEditingCommands.Print" CommandTarget="{Binding ElementName=Editor}"
                        ToolTip="Print (Ctrl+P) — choose &quot;Microsoft Print to PDF&quot; to print to a PDF"
                        AutomationProperties.Name="Print">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Print}" />
                </Button>

                <Rectangle DockPanel.Dock="Left" Style="{StaticResource CommandSeparator}" />

                <!-- Heading Level Picker. Like the Table dropdown, its entries keep their words: six
                     near-identical glyphs would separate the levels far less than the words do. -->
                <Menu DockPanel.Dock="Left" Style="{StaticResource CommandMenu}">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              ToolTip="Heading level — make the block at the caret a heading, or a paragraph again"
                              AutomationProperties.Name="Heading level">
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.SetHeadingLevel}" />
                        </MenuItem.Header>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 1"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="1" CommandTarget="{Binding ElementName=Editor}" />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 2"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="2" CommandTarget="{Binding ElementName=Editor}" />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 3"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="3" CommandTarget="{Binding ElementName=Editor}" />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 4"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="4" CommandTarget="{Binding ElementName=Editor}" />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 5"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="5" CommandTarget="{Binding ElementName=Editor}" />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Heading 6"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="6" CommandTarget="{Binding ElementName=Editor}" />
                        <Separator />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Paragraph"
                                  Command="controls:MarkdownEditingCommands.SetHeadingLevel"
                                  CommandParameter="0" CommandTarget="{Binding ElementName=Editor}" />
                    </MenuItem>
                </Menu>

                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Bold (Ctrl+B)" AutomationProperties.Name="Bold"
                        Command="EditingCommands.ToggleBold" CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleBold}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Italic (Ctrl+I)" AutomationProperties.Name="Italic"
                        Command="EditingCommands.ToggleItalic" CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleItalic}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Strikethrough — strike the selection through, or restore struck-through text"
                        AutomationProperties.Name="Strikethrough"
                        Command="controls:MarkdownEditingCommands.ToggleStrikethrough"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleStrikethrough}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Code — selection becomes a code span (one line) or code block (whole/multiple lines); click inside code to remove it"
                        AutomationProperties.Name="Code"
                        Command="controls:MarkdownEditingCommands.ToggleCode"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleCode}" />
                </Button>

                <!-- List toggles. The checklist icon matches the checkbox a Task Marker shows in
                     the document. -->
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Bulleted list — turn the selected paragraphs into a list, or a bulleted list back into paragraphs"
                        AutomationProperties.Name="Bulleted list"
                        Command="controls:MarkdownEditingCommands.ToggleUnorderedList"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleUnorderedList}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Numbered list — turn the selected paragraphs into a list, or a numbered list back into paragraphs"
                        AutomationProperties.Name="Numbered list"
                        Command="controls:MarkdownEditingCommands.ToggleOrderedList"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleOrderedList}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Checklist — give the selected list items checkboxes, or remove them; click a checkbox to tick it"
                        AutomationProperties.Name="Checklist"
                        Command="controls:MarkdownEditingCommands.ToggleTaskList"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleTaskList}" />
                </Button>

                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Insert link (Ctrl+K) — turn the selection into a link"
                        AutomationProperties.Name="Insert link"
                        Command="controls:MarkdownEditingCommands.InsertLink"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.InsertLink}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Insert image"
                        AutomationProperties.Name="Insert image"
                        Command="controls:MarkdownEditingCommands.InsertImage"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.InsertImage}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Block quote — quote the blocks the selection touches, or unquote them"
                        AutomationProperties.Name="Block quote"
                        Command="controls:MarkdownEditingCommands.ToggleBlockQuote"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleBlockQuote}" />
                </Button>

                <!-- Table dropdown: Add Table outside a Table; Add Row / Add Column inside one. The
                     entries keep their words — a dropdown is a list of choices to read, and three
                     near-identical grid icons would separate them far less than the words do. -->
                <Menu DockPanel.Dock="Left" Style="{StaticResource CommandMenu}">
                    <MenuItem Style="{StaticResource CommandMenuItem}"
                              ToolTip="Insert a table, or grow the table at the caret"
                              AutomationProperties.Name="Table">
                        <MenuItem.Header>
                            <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.Table}" />
                        </MenuItem.Header>
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Add Table"
                                  Command="controls:MarkdownEditingCommands.InsertTable"
                                  CommandTarget="{Binding ElementName=Editor}" />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Add Row"
                                  Command="controls:MarkdownEditingCommands.AddTableRow"
                                  CommandTarget="{Binding ElementName=Editor}" />
                        <MenuItem Style="{StaticResource CommandMenuEntry}" Header="Add Column"
                                  Command="controls:MarkdownEditingCommands.AddTableColumn"
                                  CommandTarget="{Binding ElementName=Editor}" />
                    </MenuItem>
                </Menu>

                <Rectangle DockPanel.Dock="Left" Style="{StaticResource CommandSeparator}" />

                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Collapse all sections" AutomationProperties.Name="Collapse all sections"
                        Command="controls:MarkdownEditingCommands.CollapseAllFolds"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.CollapseAllFolds}" />
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource IconFormatButton}"
                        ToolTip="Expand all sections (Ctrl+Shift+M)"
                        AutomationProperties.Name="Expand all sections"
                        Command="controls:MarkdownEditingCommands.ExpandAllFolds"
                        CommandTarget="{Binding ElementName=Editor}">
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ExpandAllFolds}" />
                </Button>

                <Rectangle DockPanel.Dock="Left" Style="{StaticResource CommandSeparator}" />

                <!-- Navigation Panel toggle: highlighted while the panel is shown. -->
                <Button DockPanel.Dock="Left" Command="{Binding ToggleNavigationPanelCommand}"
                        ToolTip="Toggle the navigation panel"
                        AutomationProperties.Name="Toggle the navigation panel">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconFormatButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNavigationPanelVisible}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleNavigationPanel}" />
                </Button>

                <!-- Source Panel toggle: highlighted while the raw-source pane is shown. -->
                <Button DockPanel.Dock="Left" Command="{Binding ToggleSourcePanelCommand}"
                        ToolTip="Toggle the raw Markdown source panel"
                        AutomationProperties.Name="Toggle the raw Markdown source panel">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconFormatButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSourcePanelVisible}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Style="{StaticResource CommandIcon}" Data="{StaticResource Icon.ToggleSourcePanel}" />
                </Button>

                <!-- Theme toggle: shows the theme you'd switch to. -->
                <Button DockPanel.Dock="Right" Style="{StaticResource IconCommandButton}"
                        Command="{Binding Appearance.ToggleThemeCommand}"
                        ToolTip="Toggle light / dark theme"
                        AutomationProperties.Name="Toggle light or dark theme">
                    <Path>
                        <Path.Style>
                            <Style TargetType="Path" BasedOn="{StaticResource CommandIcon}">
                                <Setter Property="Data" Value="{StaticResource Icon.ThemeDark}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Appearance.IsDarkTheme}" Value="True">
                                        <Setter Property="Data" Value="{StaticResource Icon.ThemeLight}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Button>
            </DockPanel>
        </Border>

        <!-- Tab strip: one Tab per open Editor Session, plus a new-tab button. -->
        <Border Grid.Row="1" Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Content="+"
                        FontSize="18" Margin="4,4,8,4" Command="{Binding NewCommand}"
                        ToolTip="New document (Ctrl+N)" />
                <ListBox Style="{StaticResource TabStrip}" ItemContainerStyle="{StaticResource TabItem}"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding ActiveSession, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center"
                                         Fill="{DynamicResource DirtyDotBrush}"
                                         Visibility="{Binding HasUnsavedEdits, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                <Button Style="{StaticResource TabCloseButton}" Content="&#x2715;"
                                        ToolTip="Close (Ctrl+W)"
                                        Command="{Binding DataContext.CloseSessionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Conflict banner for the Active Session: the Watched File changed on disk while there were
             unsaved edits. Neither side is discarded without an explicit choice (INV-006). -->
        <Border Grid.Row="2" Background="{DynamicResource ConflictBackgroundBrush}"
                BorderBrush="{DynamicResource ConflictBorderBrush}" BorderThickness="0,0,0,1" Padding="14,9"
                Visibility="{Binding ActiveSession.HasConflict, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <!-- View Difference: informational, so it precedes the two resolving choices. It
                         toggles the Difference Overlay and resolves nothing itself (INV-021). The
                         Content is set through the Style so the DataTrigger can swap it. -->
                    <Button Command="{Binding ActiveSession.ViewDifferenceCommand}" Margin="4,0"
                            ToolTip="Compare your unsaved edits with the file on disk">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CommandButton}">
                                <Setter Property="Content" Value="View difference" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSession.IsDifferenceVisible}" Value="True">
                                        <Setter Property="Content" Value="Hide difference" />
                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Keep my edits" Style="{StaticResource CommandButton}"
                            Command="{Binding ActiveSession.KeepMyEditsCommand}" Margin="4,0" />
                    <Button Content="Reload from disk" Style="{StaticResource CommandButton}"
                            Command="{Binding ActiveSession.ReloadFromDiskCommand}" Margin="4,0" />
                </StackPanel>
                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap"
                           Foreground="{DynamicResource ConflictTextBrush}"
                           Text="This file was changed on disk while you had unsaved edits. Keep your edits or reload the file?" />
            </DockPanel>
        </Border>

        <!-- Editing area. Shows the WYSIWYG surface (with the Editor Gutter and the toggleable
             Navigation Panel) while a Tab is open, or the Empty-Workspace Placeholder when every Tab
             has been closed (INV-008). -->
        <Grid Grid.Row="3">

            <!-- The WYSIWYG editing surface, bound to the Active Session, with the Editor Gutter (line
                 numbers + fold chevrons) alongside it, the Navigation Panel (the toggleable Outline) to
                 its left, and the toggleable Source Panel (raw Markdown source) split to its right. -->
            <Grid Visibility="{Binding HasOpenSessions, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{Binding IsSourcePanelVisible, Converter={StaticResource BooleanToGridLengthConverter}, ConverterParameter=420}" />
                </Grid.ColumnDefinitions>

                <!-- Navigation Panel: the Active Session's Outline. Hidden until toggled on (INV-012). -->
                <Border Grid.Column="0" Width="250" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                        Visibility="{Binding IsNavigationPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="OUTLINE" Margin="14,12,14,6"
                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" />
                        <controls:OutlinePanel Editor="{Binding ElementName=Editor}"
                                               AutomationProperties.AutomationId="OutlineList" />
                    </DockPanel>
                </Border>

                <controls:EditorGutter Grid.Column="1" Editor="{Binding ElementName=Editor}" />
                <controls:MarkdownRichEditor x:Name="Editor" Grid.Column="2"
                                             Markdown="{Binding ActiveSession.Markdown, UpdateSourceTrigger=PropertyChanged}"
                                             BaseDirectory="{Binding ActiveSession.BaseDirectory}"
                                             LinkPrompt="{Binding LinkPrompt}"
                                             DocumentPrinter="{Binding DocumentPrinter}"
                                             Renderer="{Binding Renderer}"
                                             FollowLinkCommand="{Binding FollowLinkCommand}"
                                             controls:ScrollSync.SyncPartner="{Binding ElementName=SourcePanel}" />

                <!-- Splitter between the Visual Document and the Source Panel. Hidden with the panel. -->
                <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns" Background="{DynamicResource BorderBrush}"
                              Visibility="{Binding IsSourcePanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- Source Panel: the Active Session's raw, editable Markdown source, two-way bound to
                     the same canonical Markdown as the Visual Document so the two stay in sync
                     (INV-013). It is the one surface that shows Markdown syntax. Hidden until toggled
                     on (INV-014). -->
                <Border Grid.Column="4" Background="{DynamicResource EditorBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                        Visibility="{Binding IsSourcePanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="SOURCE" Margin="14,12,14,6"
                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" />
                        <!-- The Source Gutter (Line Numbers) mirrors the source TextBox's line layout.
                             The TextBox does not wrap, so each source line is a single row aligned to
                             its Line Number. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <controls:SourceGutter Grid.Column="0" Source="{Binding ElementName=SourcePanel}" />
                            <!-- Delay debounces the source→Visual-Document projection: keystrokes coalesce
                                 so a full re-Project runs once typing pauses, not on every key. The TextBox
                                 (the binding target) stays instantly responsive. -->
                            <TextBox Grid.Column="1" x:Name="SourcePanel"
                                     AutomationProperties.AutomationId="SourcePanel"
                                     Text="{Binding ActiveSession.Markdown, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                                     controls:ScrollSync.SyncPartner="{Binding ElementName=Editor}"
                                     AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                     FontFamily="Cascadia Code, Consolas, monospace" FontSize="13"
                                     Background="Transparent" BorderThickness="0" Padding="6,4,12,12"
                                     Foreground="{DynamicResource TextBrush}"
                                     CaretBrush="{DynamicResource TextBrush}"
                                     SpellCheck.IsEnabled="True" />
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Empty-Workspace Placeholder: shown when no Tab is open. -->
            <Border Background="{DynamicResource EditorBackgroundBrush}"
                    Visibility="{Binding IsWorkspaceEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="No document open" FontSize="16" HorizontalAlignment="Center"
                               Margin="0,0,0,6" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="Press + to start a new document, or Open a file"
                               FontSize="12" HorizontalAlignment="Center"
                               Foreground="{DynamicResource MutedTextBrush}" />
                </StackPanel>
            </Border>

            <!-- Find Bar: floats over the editor's top-right, bound to the editor's Find state. Opened
                 with Ctrl+F (which focuses the query box) or Ctrl+H (which also shows the Replace
                 Row), dismissed with Escape. The Find row is view-only — finding never changes the
                 Markdown Document (INV-016) — while the Replace Row's two commands are real edits
                 that Capture back into it (INV-022). -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,26,0"
                    Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="8,5"
                    Visibility="{Binding IsFindActive, ElementName=Editor, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="12" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="FindQueryBox" Width="220" Style="{StaticResource FindBarTextBox}"
                                 controls:Watermark.Text="Find"
                                 controls:FocusOnVisible.Enabled="True"
                                 Text="{Binding FindQuery, ElementName=Editor, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="controls:MarkdownEditingCommands.FindNext"
                                            CommandTarget="{Binding ElementName=Editor}" />
                                <KeyBinding Key="Enter" Modifiers="Shift"
                                            Command="controls:MarkdownEditingCommands.FindPrevious"
                                            CommandTarget="{Binding ElementName=Editor}" />
                                <KeyBinding Key="Esc" Command="controls:MarkdownEditingCommands.HideFind"
                                            CommandTarget="{Binding ElementName=Editor}" />
                            </TextBox.InputBindings>
                        </TextBox>

                        <TextBlock Text="{Binding MatchSummary, ElementName=Editor}" MinWidth="56"
                                   VerticalAlignment="Center" TextAlignment="Right" Margin="8,0"
                                   FontSize="12" Foreground="{DynamicResource MutedTextBrush}" />

                        <Rectangle Style="{StaticResource CommandSeparator}" />

                        <Button Style="{StaticResource IconButton}" Content="&#x2191;" FontSize="13"
                                ToolTip="Previous match (Shift+Enter)"
                                Command="controls:MarkdownEditingCommands.FindPrevious"
                                CommandTarget="{Binding ElementName=Editor}" />
                        <Button Style="{StaticResource IconButton}" Content="&#x2193;" FontSize="13"
                                ToolTip="Next match (Enter)"
                                Command="controls:MarkdownEditingCommands.FindNext"
                                CommandTarget="{Binding ElementName=Editor}" />
                        <Button Style="{StaticResource IconButton}" Content="&#x2715;" FontSize="12"
                                ToolTip="Close (Esc)"
                                Command="controls:MarkdownEditingCommands.HideFind"
                                CommandTarget="{Binding ElementName=Editor}" />
                    </StackPanel>

                    <!-- Replace Row: shown only when the Find Bar was opened for Replace (Ctrl+H),
                         divided from the Find row above it. -->
                    <StackPanel Visibility="{Binding IsReplaceActive, ElementName=Editor, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Rectangle Style="{StaticResource PanelSeparator}" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="ReplacementBox" Width="220" Style="{StaticResource FindBarTextBox}"
                                     controls:Watermark.Text="Replace"
                                     Text="{Binding Replacement, ElementName=Editor, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="controls:MarkdownEditingCommands.Replace"
                                                CommandTarget="{Binding ElementName=Editor}" />
                                    <KeyBinding Key="Esc" Command="controls:MarkdownEditingCommands.HideFind"
                                                CommandTarget="{Binding ElementName=Editor}" />
                                </TextBox.InputBindings>
                            </TextBox>

                            <Button Style="{StaticResource FindBarButton}" Content="Replace" Margin="8,0,0,0"
                                    ToolTip="Replace the current match (Enter)"
                                    Command="controls:MarkdownEditingCommands.Replace"
                                    CommandTarget="{Binding ElementName=Editor}" />
                            <Button Style="{StaticResource FindBarButton}" Content="Replace all"
                                    ToolTip="Replace every match, including any inside collapsed sections"
                                    Command="controls:MarkdownEditingCommands.ReplaceAll"
                                    CommandTarget="{Binding ElementName=Editor}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Difference Overlay: the Active Session's Conflict Difference, covering the whole
                 editing area (the Source Panel included — it edits the same Markdown, so leaving it
                 live beneath an open comparison would invite edits against the view) while the
                 Conflict bar above stays visible. Last child = topmost. View-only: computing,
                 showing, or hiding it never changes the Markdown Document, the Watched File, or the
                 Conflict (INV-021). -->
            <Border Background="{DynamicResource EditorBackgroundBrush}"
                    Visibility="{Binding ActiveSession.IsDifferenceVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="14,12,14,6" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="DIFFERENCE &#x2014; YOUR UNSAVED EDITS (&#x2212;) VS THE FILE ON DISK (+)" />
                    <!-- The ScrollViewer lives inside the template so the VirtualizingStackPanel gets a
                         real viewport; an outer ScrollViewer would give it infinite height and defeat
                         virtualisation on a long document. -->
                    <ItemsControl ItemsSource="{Binding ActiveSession.DifferenceLines}" Focusable="False"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer Focusable="False" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="LineRoot" Padding="14,1">
                                    <DockPanel>
                                        <TextBlock x:Name="Marker" DockPanel.Dock="Left" Width="16" Text=" "
                                                   FontFamily="Cascadia Code, Consolas, monospace" FontSize="13"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Text}" FontSize="13"
                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                   Foreground="{DynamicResource TextBrush}" />
                                    </DockPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Kind}" Value="SessionOnly">
                                        <Setter TargetName="LineRoot" Property="Background"
                                                Value="{DynamicResource DifferenceRemovedBrush}" />
                                        <Setter TargetName="Marker" Property="Text" Value="&#x2212;" />
                                        <Setter TargetName="Marker" Property="Foreground"
                                                Value="{DynamicResource DifferenceRemovedTextBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Kind}" Value="DiskOnly">
                                        <Setter TargetName="LineRoot" Property="Background"
                                                Value="{DynamicResource DifferenceAddedBrush}" />
                                        <Setter TargetName="Marker" Property="Text" Value="+" />
                                        <Setter TargetName="Marker" Property="Foreground"
                                                Value="{DynamicResource DifferenceAddedTextBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Slim status bar: the Watched File path and an unsaved-changes hint. -->
        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,4">
            <DockPanel Visibility="{Binding HasOpenSessions, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource StatusText}" Text="Unsaved changes"
                           Margin="12,0,0,0"
                           Visibility="{Binding ActiveSession.HasUnsavedEdits, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Style="{StaticResource StatusText}"
                           Text="{Binding ActiveSession.FilePath, TargetNullValue='Unsaved document'}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
