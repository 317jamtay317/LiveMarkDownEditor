<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:UI.Controls">

    <!-- Flat, rounded control styles for the editor shell. All colours are DynamicResource lookups
         into the active palette (Palette.Light.xaml / Palette.Dark.xaml) so a theme swap recolours
         everything live. -->

    <!-- A flat text button for the command bar (New / Open / Save). -->
    <Style x:Key="CommandButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <!-- Show the Command Tip even while the command is disabled: a greyed-out action is exactly
             when the user most wants to know what it is and why it is unavailable. -->
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bold / Italic formatting buttons: same flat look, fixed width, larger glyph. Not focusable,
         so clicking them keeps focus (and the visible selection) in the editor they target. -->
    <Style x:Key="FormatButton" TargetType="Button" BasedOn="{StaticResource CommandButton}">
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Focusable" Value="False" />
    </Style>

    <!-- A Command Icon: one of the 24x24 outlines in Icons.xaml, drawn as the content of a command
         bar button. Three decisions worth keeping:

         - Stretch="None" with a fixed 24x24 box and a LayoutTransform, rather than Stretch="Uniform".
           Uniform scales each icon to fill its box, so icons with a smaller natural extent (the fold
           chevrons) would be magnified next to wider ones (the code brackets) and the set would lose
           its common weight. Scaling the whole grid instead keeps every icon to one scale, and draws
           each where its own coordinates put it. The transform is a LayoutTransform, not a
           RenderTransform, so the button measures the icon at its drawn 18x18 rather than 24x24.
         - The stroke is the inherited TextElement.Foreground, which is the button's Foreground and so
           the palette's TextBrush. That is what carries an icon across a theme swap, and what fades
           it with the button's IsEnabled trigger.
         - StrokeThickness is 2 on the 24x24 grid, which the 0.75 scale draws as 1.5px. -->
    <Style x:Key="CommandIcon" TargetType="Path">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Stretch" Value="None" />
        <Setter Property="Fill" Value="{x:Null}" />
        <Setter Property="Stroke"
                Value="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource Self}}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="LayoutTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="0.75" ScaleY="0.75" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- An icon-only command bar button, square so that a row of icons reads as a row of equals
         rather than as words of differing length. Every use MUST set AutomationProperties.Name:
         dropping the word takes with it the only thing that named the button to a screen reader.
         Focusable, so the button is still reachable by Tab — the icon-only counterpart of
         CommandButton. -->
    <Style x:Key="IconCommandButton" TargetType="Button" BasedOn="{StaticResource CommandButton}">
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="Padding" Value="7,6" />
    </Style>

    <!-- An icon-only button that acts on the editor. Not focusable, so clicking it keeps focus (and
         the visible selection) in the editor it targets — the icon-only counterpart of
         FormatButton. -->
    <Style x:Key="IconFormatButton" TargetType="Button" BasedOn="{StaticResource IconCommandButton}">
        <Setter Property="Focusable" Value="False" />
    </Style>

    <!-- The chevron marking a command bar dropdown. Drawn rather than typed: as a 9px "&#x25BE;" it
         rendered as a three-pixel smudge of subpixel colour, which reads as dirt beside a vector
         icon. Its data is inline because it belongs to this style rather than to the Command Icon
         set — it is an affordance on the button, not the icon that names it — and because a
         StaticResource here could not see a sibling dictionary merged alongside this one. -->
    <Style x:Key="DropdownChevron" TargetType="Path">
        <Setter Property="Data" Value="M1 3 L5 7 L9 3" />
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="Stretch" Value="None" />
        <Setter Property="Fill" Value="{x:Null}" />
        <Setter Property="Stroke"
                Value="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource Self}}" />
        <Setter Property="StrokeThickness" Value="1.4" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
    </Style>

    <!-- Square icon button (theme toggle, new-tab "+"). -->
    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource CommandButton}">
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <!-- A command-bar dropdown (e.g. the Table menu): a Menu holding one top-level MenuItem that
         looks like a CommandButton and opens its entries in a rounded surface panel. -->
    <Style x:Key="CommandMenu" TargetType="Menu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- The dropdown's top-level item: CommandButton look plus a chevron, submenu below. -->
    <Style x:Key="CommandMenuItem" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                Padding="12,6" Margin="1,0">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <Path Style="{StaticResource DropdownChevron}" Margin="4,1,0,0"
                                      VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Popup x:Name="PART_Popup" Placement="Bottom" VerticalOffset="2"
                               AllowsTransparency="True" Focusable="False" PopupAnimation="Fade"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="4" Margin="0,0,8,8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="12" ShadowDepth="2" />
                                </Border.Effect>
                                <ItemsPresenter />
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- One entry within a command-bar dropdown. Disabled entries fade, matching CommandButton. -->
    <Style x:Key="CommandMenuEntry" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="5"
                            Padding="12,6" MinWidth="130">
                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- A checkable entry within a command-bar dropdown: shows a check when IsChecked, which is bound to
         the state it toggles (e.g. a panel's visibility). The View dropdown uses it for the panel
         toggles, standing in for each toggle button's active highlight. -->
    <Style x:Key="CommandMenuToggleEntry" TargetType="MenuItem" BasedOn="{StaticResource CommandMenuEntry}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="12,6" MinWidth="180">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" ContentSource="Header" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                            <Path x:Name="Check" Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center"
                                  Stretch="None" Fill="{x:Null}" Stroke="{DynamicResource TextBrush}"
                                  StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Data="M0 5 L4 9 L11 1" Visibility="Hidden" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Thin vertical divider between command-bar groups. -->
    <Style x:Key="CommandSeparator" TargetType="Rectangle">
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="7,7" />
        <Setter Property="Fill" Value="{DynamicResource BorderBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- Thin horizontal divider between the rows of a floating panel (the Find Bar's Find row and
         its Replace Row). The horizontal counterpart of CommandSeparator. -->
    <Style x:Key="PanelSeparator" TargetType="Rectangle">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="0,5" />
        <Setter Property="Fill" Value="{DynamicResource BorderBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- A borderless text box for the Find Bar, showing its Watermark (controls:Watermark.Text)
         while empty — without it an empty, unfocused box is invisible against the panel. -->
    <Style x:Key="FindBarTextBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource CaretBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <!-- Sits behind the text host, so it is covered the moment anything is
                             typed; hit-test invisible so clicking it still focuses the box. -->
                        <TextBlock x:Name="Watermark" Visibility="Collapsed" IsHitTestVisible="False"
                                   Text="{Binding (controls:Watermark.Text), RelativeSource={RelativeSource TemplatedParent}}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="{TemplateBinding FontSize}"
                                   VerticalAlignment="Center" Margin="2,0,0,0" />
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The default look for a plain text box: the dialogs' text fields (the Link Prompt's text and URL,
         the Flowchart Builder's edge label). WPF's stock TextBox is a white, system-drawn control that
         ignores the palette, so in the dark theme it reads as a glaring white box; this implicit style
         paints it from the palette instead. Two neighbours override it and are left untouched: the Find
         Bar's box carries its own keyed FindBarTextBox style, and the Source Panel (and the canvas rename
         box) set a transparent/own background locally, which wins over these setters. -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource CaretBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBrush}" />
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" SnapsToDevicePixels="True">
                        <!-- Named PART_ContentHost and kept a ScrollViewer so TextBoxBase still drives it —
                             the Source Panel's Scroll Sync reads VerticalOffset/ExtentHeight through it. -->
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                                      VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The default look for a tooltip. WPF's stock ToolTip is a pale, system-drawn popup that ignores
         the palette — in the dark theme it reads as a glaring near-white box, exactly like the stock
         TextBox and ComboBox above. This implicit style paints it from the palette instead, so a bare
         string tooltip (the Editor Gutter's Fold Toggle, the Flowchart Builder's connector handle) is
         themed with everything else. The Command Bar's richer tooltips are Command Tips, which carry
         their own template (Controls/CommandTip.xaml); this styles the plain-string ones. -->
    <Style TargetType="ToolTip">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="MaxWidth" Value="300" />
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <!-- Wrap a long hint rather than clip it at MaxWidth. -->
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.22" BlurRadius="14" ShadowDepth="2" />
                        </Border.Effect>
                        <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- A compact text button for the Find Bar's Replace Row: the flat CommandButton look, sized to
         sit beside the query and Replacement boxes rather than in the command bar. Its vertical
         padding and font match the row above's icon buttons, so the Replace Row stands exactly as
         tall as the Find row and the bar reads as one grid. -->
    <Style x:Key="FindBarButton" TargetType="Button" BasedOn="{StaticResource CommandButton}">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="4,0,0,0" />
    </Style>

    <!-- The button that dismisses a dialog (the Link Prompt's Cancel): outlined rather than filled,
         so it reads as the quieter of the pair beside the Primary Dialog Button. Its fill is the
         dialog's own SurfaceBrush, which leaves the outline to draw the button — and gives the hover
         and pressed fills something to replace. Unlike a CommandButton this one is deliberately
         bordered: a dialog's buttons sit on open surface with nothing else to bound them. -->
    <Style x:Key="DialogButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The button that commits a dialog (the Link Prompt's Insert): filled with the accent, so the
         action the user came for is the one their eye lands on. It carries its own template rather
         than BasedOn the DialogButton because that style's hover swaps the fill for HoverBrush, which
         would grey out the accent on hover; here hover and press dim the accent itself instead. The
         disabled fade is shared with every other button, and earns its keep: Insert stays disabled
         until a URL is given (INV-030), so this is the state the dialog opens in. -->
    <Style x:Key="PrimaryDialogButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.76" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The default look for a dropdown: the Flowchart Builder's direction / shape / edge pickers. Like
         the text box above, WPF's stock ComboBox is a white, system-drawn control that ignores the
         palette; this implicit style paints both the closed box and its open drop-down list from the
         palette so a dropdown matches the theme in the dark theme rather than glaring white. -->
    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- The whole box is one press-to-open toggle, its checked state bound to the
                             drop-down; the selection text and chevron sit over it, hit-test invisible. -->
                        <ToggleButton x:Name="Toggle" Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd" Background="{DynamicResource EditorBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="6" SnapsToDevicePixels="True" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <ContentPresenter IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          Margin="10,0,28,0" VerticalAlignment="Center" HorizontalAlignment="Left"
                                          TextElement.Foreground="{DynamicResource TextBrush}" />

                        <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,11,0"
                              Data="M1 3 L5 7 L9 3" Width="10" Height="10" Stretch="None" Fill="{x:Null}"
                              Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="1.4"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              IsHitTestVisible="False" />

                        <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                               Focusable="False" PopupAnimation="Fade"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="4" Margin="0,2,0,8"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="12" ShadowDepth="2" />
                                </Border.Effect>
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- One entry in a dropdown's open list: flat, with the same HoverBrush highlight as a menu entry. -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="10,6" SnapsToDevicePixels="True">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The tab strip: a horizontal ListBox with no chrome. -->
    <Style x:Key="TabStrip" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,0,0,0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- A single Tab: transparent when inactive, editor-coloured with an accent top edge when active. -->
    <Style x:Key="TabItem" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="8,8,0,0" Margin="1,4,1,0">
                        <Border x:Name="Accent" BorderThickness="0,2,0,0" BorderBrush="Transparent"
                                CornerRadius="8,8,0,0" Padding="12,7">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource EditorBackgroundBrush}" />
                            <Setter TargetName="Accent" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The small "×" that closes a Tab; turns red on hover. -->
    <Style x:Key="TabCloseButton" TargetType="Button">
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CloseHoverBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource CloseHoverTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Muted status-bar text. -->
    <Style x:Key="StatusText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

</ResourceDictionary>
