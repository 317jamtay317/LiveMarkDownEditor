<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Command Icons: the vector glyph the Command Bar shows for each of its actions, in place of
         a word. Presentation-only — an icon names an action, it never performs one.

         Every icon is authored as an outline on the same 24x24 grid and is drawn stroked, not
         filled, by the CommandIcon style in Controls.xaml. Two consequences worth keeping:

         - Stay inside the grid. The CommandIcon style renders at Stretch="None" so that every icon
           is scaled by the same factor and they share a weight; an icon is positioned by its own
           coordinates, so one drawn outside 0..24 lands off-centre rather than being scaled to fit.
         - Corners are square here. The stroke is drawn with rounded joins and caps, which rounds
           them on screen, so the path data does not need arcs to look soft.

         Geometry is not a brush, so WpfThemeService leaves this dictionary alone on a theme swap
         (it recolours SolidColorBrush entries only). Icons follow the theme through the stroke,
         which inherits the button's Foreground. -->

    <!-- File actions. -->

    <!-- A page with a folded corner and a plus. -->
    <Geometry x:Key="Icon.New">M6 3 H14 L19 8 V21 H6 Z M14 3 V8 H19 M12.5 12 V18 M9.5 15 H15.5</Geometry>

    <!-- A folder. -->
    <Geometry x:Key="Icon.Open">M3 20 V5 H9.5 L11.5 8 H21 V20 Z</Geometry>

    <!-- A floppy disk: still the one shape every editor agrees means "save". -->
    <Geometry x:Key="Icon.Save">M4 4 H16 L20 8 V20 H4 Z M8 4 V9 H15 V4 M7 20 V14 H17 V20</Geometry>

    <!-- An open tray with content rising up and out of it: the export glyph. It is not a floppy
         (Save) or a folder (Open) — it says the document leaves as a new file, which is exactly what
         Export as HTML does. There is no upload or cloud in this app for the outbound arrow to be
         confused with. -->
    <Geometry x:Key="Icon.ExportHtml">M4 13 V20 H20 V13 M12 15 V3 M7.5 7.5 L12 3 L16.5 7.5</Geometry>

    <!-- A document with a down arrow: saving the document out as a file, for Export as PDF. The page
         says "document"; the down arrow says "written to a file". It is deliberately unlike the
         Export as HTML tray (which sends a fragment up and out) — a PDF is a whole document saved. -->
    <Geometry x:Key="Icon.ExportPdf">M7 3 H13 L17 7 V21 H7 Z M13 3 V7 H17 M12 10 V16 M9.5 13.5 L12 16 L14.5 13.5</Geometry>

    <!-- A printer: the top sheet feeding in, the printer body with its paper slot, and the printed
         sheet emerging below. The one shape every editor agrees means "print". -->
    <Geometry x:Key="Icon.Print">M7 8 V3 H17 V8 M4 8 H20 V16 H4 Z M7 12 H17 M8 16 H16 V21 H8 Z</Geometry>

    <!-- Print Preview: a page with a magnifier over it — the printed page, being looked at before it
         is printed (INV-061). -->
    <Geometry x:Key="Icon.PrintPreview">M6 3 H18 V21 H6 Z M11.5 8 A3.2 3.2 0 1 1 11.5 14.4 A3.2 3.2 0 1 1 11.5 8 Z M13.8 13.5 L16.5 16.5</Geometry>

    <!-- Page Setup: a page with its margin drawn inside — the frame the Print Margins inset and the
         Page Orientation turns (INV-061). -->
    <Geometry x:Key="Icon.PageSetup">M6 3 H18 V21 H6 Z M9 6.5 H15 V17.5 H9 Z</Geometry>

    <!-- A clock, for Open Recent: the "history / recently used" glyph, a circle with two hands. -->
    <Geometry x:Key="Icon.OpenRecent">M12 4 A8 8 0 0 1 12 20 A8 8 0 0 1 12 4 Z M12 8 V12 L15 14</Geometry>

    <!-- Formatting Actions. -->

    <!-- A bold letter B, drawn as its two bowls over a shared stem. -->
    <Geometry x:Key="Icon.ToggleBold">M7 4 H14 A4 4 0 0 1 14 12 H7 Z M7 12 H15 A4 4 0 0 1 15 20 H7 Z</Geometry>

    <!-- A capital H, for the Heading Level Picker. No level numeral rides along with it: the dropdown
         names all six levels in words, and a glyph reading "H1" would claim the button sets that one. -->
    <Geometry x:Key="Icon.SetHeadingLevel">M7 5 V19 M17 5 V19 M7 12 H17</Geometry>

    <!-- A slanted letter I, serifed top and bottom so the slant reads at 18px. -->
    <Geometry x:Key="Icon.ToggleItalic">M10 4 H19 M5 20 H14 M15 4 L9 20</Geometry>

    <!-- A letter S with a rule struck through it, joining the B and the I as a letter. The rule runs
         wider than the S so it reads as struck rather than as an S with a serif. -->
    <Geometry x:Key="Icon.ToggleStrikethrough">M15.5 7.5 C15.5 5.2 13.9 4 12 4 C10.1 4 8.5 5.2 8.5 7 C8.5 10.4 15.5 10 15.5 14 C15.5 16.4 13.9 18 12 18 C10.1 18 8.5 16.8 8.5 15 M4 12 H20</Geometry>

    <!-- Angle brackets around a slash: the same shape the button showed as text. The slash matters —
         without it the two brackets read as a spaced-apart "< >" rather than as code. -->
    <Geometry x:Key="Icon.ToggleCode">M17 7 L22 12 L17 17 M7 7 L2 12 L7 17 M14.5 4 L9.5 20</Geometry>

    <!-- Three lines behind bullets. -->
    <Geometry x:Key="Icon.ToggleUnorderedList">M3.1 6 A0.9 0.9 0 1 0 4.9 6 A0.9 0.9 0 1 0 3.1 6 Z M3.1 12 A0.9 0.9 0 1 0 4.9 12 A0.9 0.9 0 1 0 3.1 12 Z M3.1 18 A0.9 0.9 0 1 0 4.9 18 A0.9 0.9 0 1 0 3.1 18 Z M9 6 H21 M9 12 H21 M9 18 H21</Geometry>

    <!-- Three lines behind a 1 and a 2. -->
    <Geometry x:Key="Icon.ToggleOrderedList">M3.5 5 L5 4 V10 M3.5 10 H6.5 M3.2 15 Q3.2 13.6 4.9 13.6 Q6.6 13.6 6.6 15.2 Q6.6 16.6 3.2 20 H6.8 M10 6 H21 M10 12 H21 M10 18 H21</Geometry>

    <!-- Three lines behind ticks: the checkbox a Task Marker shows in the document. -->
    <Geometry x:Key="Icon.ToggleTaskList">M3 6.2 L4.6 7.8 L7.6 4.8 M3 17.2 L4.6 18.8 L7.6 15.8 M11 6 H21 M11 12 H21 M11 18 H21</Geometry>

    <!-- Two links of a chain, drawn as the classic broken-diagonal link. -->
    <Geometry x:Key="Icon.InsertLink">M10 14 A4 4 0 0 0 15.6 14 L19 10.6 A4 4 0 0 0 13.4 5 L11.7 6.7 M14 10 A4 4 0 0 0 8.4 10 L5 13.4 A4 4 0 0 0 10.6 19 L12.3 17.3</Geometry>

    <!-- A framed picture: a sun over a mountain, the one shape that reads as "image" at 18px. -->
    <Geometry x:Key="Icon.InsertImage">M3 5 H21 V19 H3 Z M7.5 9.5 A1.2 1.2 0 1 0 9.9 9.5 A1.2 1.2 0 1 0 7.5 9.5 Z M3 16 L8.5 11.5 L13 15 L16.5 12.5 L21 16.5</Geometry>

    <!-- A left rule beside lines of text: the same shape a Block Quote is shown with in the Visual
         Document, the way the checklist icon matches the checkbox a Task Marker shows. The last line
         is short so the block reads as prose rather than as a table. -->
    <Geometry x:Key="Icon.ToggleBlockQuote">M4 5 V19 M9 7 H20 M9 12 H20 M9 17 H16</Geometry>

    <!-- A header row over two cells, for the Table dropdown. Deliberately not a full 3x3 grid: at
         18px the extra rules crowd into a mesh and stop reading as a table at all. -->
    <Geometry x:Key="Icon.Table">M3 5 H21 V19 H3 Z M3 10 H21 M12 10 V19</Geometry>

    <!-- Fold actions: chevrons that close toward a line, and open away from it. The line is what
         makes them legible — two facing chevrons alone merge into an X (collapse) and a diamond
         (expand), which say nothing. It also reads as the Section Heading the fold closes onto. -->
    <Geometry x:Key="Icon.CollapseAllFolds">M3 12 H21 M8 3.5 L12 8 L16 3.5 M8 20.5 L12 16 L16 20.5</Geometry>
    <Geometry x:Key="Icon.ExpandAllFolds">M3 12 H21 M8 8 L12 3.5 L16 8 M8 16 L12 20.5 L16 16</Geometry>

    <!-- Panel toggles. Each shows the pane it opens on the side it opens: the Navigation Panel to
         the left of the editing surface, the Source Panel to its right. -->
    <Geometry x:Key="Icon.ToggleNavigationPanel">M3 4 H21 V20 H3 Z M9 4 V20</Geometry>
    <Geometry x:Key="Icon.ToggleSourcePanel">M3 4 H21 V20 H3 Z M15 4 V20</Geometry>

    <!-- Preview Panel toggle: a small flowchart — two nodes and a connector — for the Diagram Preview. -->
    <Geometry x:Key="Icon.TogglePreviewPanel">M4 5 H10 V9 H4 Z M14 15 H20 V19 H14 Z M10 7 H12 V17 H14</Geometry>

    <!-- Page View toggle: a page (a bordered sheet with lines of text) for the fixed-width Document Sheet. -->
    <Geometry x:Key="Icon.TogglePageView">M6 3 H18 V21 H6 Z M9 7 H15 M9 11 H15 M9 15 H15 M9 18 H13</Geometry>

    <!-- Flowchart Builder: two nodes joined by an elbow connector with an arrowhead — the graphical
         node/arrow builder (INV-053). -->
    <Geometry x:Key="Icon.Flowchart">M3 4 H9 V8 H3 Z M15 16 H21 V20 H15 Z M6 8 V13 H18 V16 M16.5 14 L18 16 L19.5 14</Geometry>

    <!-- Folder Workspace. Open Folder is a folder with a plus (open a whole folder as a workspace);
         the Folder Panel toggle is a left pane showing a file list, distinct from the Navigation
         Panel's plain divider. The node glyphs — a folder and a lined document — mark tree entries. -->
    <Geometry x:Key="Icon.OpenFolder">M3 20 V5 H9.5 L11.5 8 H21 V20 Z M12 11.5 V16.5 M9.5 14 H14.5</Geometry>
    <Geometry x:Key="Icon.ToggleFolderPanel">M3 4 H21 V20 H3 Z M9 4 V20 M5 8 H7 M5 12 H7 M5 16 H7</Geometry>
    <Geometry x:Key="Icon.Folder">M3 19 V6 H9 L11 9 H21 V19 Z</Geometry>
    <Geometry x:Key="Icon.MarkdownFile">M6 3 H14 L18 7 V21 H6 Z M14 3 V7 H18 M9 12 H15 M9 15 H14</Geometry>

    <!-- A circular arrow, for re-reading the Folder Workspace from disk (Refresh). -->
    <Geometry x:Key="Icon.Refresh">M18 8 A7 7 0 1 0 19 12 M18 8 H14 M18 8 V12</Geometry>

    <!-- Theme toggle. Each shows the theme it switches you to, not the one you are in. -->
    <Geometry x:Key="Icon.ThemeDark">M12 3 A6 6 0 0 0 21 12 A9 9 0 1 1 12 3 Z</Geometry>
    <Geometry x:Key="Icon.ThemeLight">M8 12 A4 4 0 1 0 16 12 A4 4 0 1 0 8 12 Z M12 2 V4.5 M12 19.5 V22 M2 12 H4.5 M19.5 12 H22 M4.9 4.9 L6.7 6.7 M17.3 17.3 L19.1 19.1 M19.1 4.9 L17.3 6.7 M6.7 17.3 L4.9 19.1</Geometry>

    <!-- Insert dropdown: a plus — the header for the menu that inserts links, images, tables, and more. -->
    <!-- Panel Chrome (INV-062): the Panel Header's Pin Toggle (upright while pinned, sideways while
         unpinned), its Close Button, and the Editor Pane's View-menu toggle. -->
    <Geometry x:Key="Icon.Pin">M9.5 3.5 H14.5 V9 L17 11.5 H7 L9.5 9 Z M12 11.5 V20</Geometry>
    <Geometry x:Key="Icon.PinOff">M3.5 9.5 V14.5 H9 L11.5 17 V7 L9 9.5 Z M11.5 12 H20</Geometry>
    <Geometry x:Key="Icon.Close">M6.5 6.5 L17.5 17.5 M17.5 6.5 L6.5 17.5</Geometry>
    <Geometry x:Key="Icon.ToggleEditorPane">M3 4 H21 V20 H3 Z M7 9 H17 M7 13 H17 M7 17 H13</Geometry>

    <Geometry x:Key="Icon.Insert">M12 5 V19 M5 12 H19</Geometry>

    <!-- View dropdown: an eye — the header for the menu that shows or hides the panels beside the document. -->
    <Geometry x:Key="Icon.View">M3 12 C7 7 17 7 21 12 C17 17 7 17 3 12 Z M9.5 12 A2.5 2.5 0 1 0 14.5 12 A2.5 2.5 0 1 0 9.5 12 Z</Geometry>

</ResourceDictionary>
