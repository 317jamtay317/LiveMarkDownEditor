<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light palette. Every key here also exists in Palette.Dark.xaml; the WpfThemeService swaps
         which one is merged, and the control styles reference these via DynamicResource, so the
         whole UI recolours live. -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F0F1F3" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#FFFFFF" />

    <SolidColorBrush x:Key="TextBrush" Color="#1F2328" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#6E7781" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E4E8" />

    <SolidColorBrush x:Key="AccentBrush" Color="#4F46E5" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="HoverBrush" Color="#E9EAEE" />

    <!-- Code Shading: a subtle translucent tint drawn behind code by the CodeShadingAdorner overlay
         (not as the code's own background, so a theme recolour never re-formats the document). -->
    <SolidColorBrush x:Key="CodeShadingBrush" Color="#18000000" />

    <!-- Scrollbar thumb: the accent colour, muted at rest and full-strength on hover/drag. -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#4F46E5" Opacity="0.55" />

    <SolidColorBrush x:Key="CaretBrush" Color="#1F2328" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#C7D2FE" />
    <SolidColorBrush x:Key="DirtyDotBrush" Color="#4F46E5" />

    <SolidColorBrush x:Key="ConflictBackgroundBrush" Color="#FFF4E5" />
    <SolidColorBrush x:Key="ConflictBorderBrush" Color="#E0A800" />
    <SolidColorBrush x:Key="ConflictTextBrush" Color="#7A5A00" />

    <!-- Conflict Difference: the line backgrounds and the -/+ markers of the View Difference
         overlay. Removed (-) is the Editor Session's unsaved side; added (+) is the on-disk side. -->
    <SolidColorBrush x:Key="DifferenceRemovedBrush" Color="#FDE8E8" />
    <SolidColorBrush x:Key="DifferenceRemovedTextBrush" Color="#C0342B" />
    <SolidColorBrush x:Key="DifferenceAddedBrush" Color="#E2F5E7" />
    <SolidColorBrush x:Key="DifferenceAddedTextBrush" Color="#1A7F37" />

    <SolidColorBrush x:Key="CloseHoverBrush" Color="#F1DADB" />
    <SolidColorBrush x:Key="CloseHoverTextBrush" Color="#C0342B" />

</ResourceDictionary>
