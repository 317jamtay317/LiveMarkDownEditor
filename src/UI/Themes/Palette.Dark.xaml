<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark palette. Mirrors every key in Palette.Light.xaml with dark-theme values. -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#171719" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#202024" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#1E1E22" />
    <!-- Editing canvas: the muted surround the Document Sheet floats on in Page View, darker than the
         Sheet (EditorBackgroundBrush) so the page edge reads clearly (INV-058). -->
    <SolidColorBrush x:Key="EditorCanvasBrush" Color="#111114" />
    <!-- Page Break: the rule the PageBreakAdorner draws across the Sheet where one Page ends and the
         next begins, in the canvas colour so a break reads as the seam between two sheets (INV-058). -->
    <SolidColorBrush x:Key="PageBreakBrush" Color="#37373E" />

    <SolidColorBrush x:Key="TextBrush" Color="#E6E6E9" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#8B8B95" />
    <SolidColorBrush x:Key="BorderBrush" Color="#2E2E34" />

    <SolidColorBrush x:Key="AccentBrush" Color="#7C6CF0" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="HoverBrush" Color="#26262B" />

    <!-- Code Shading: a subtle translucent tint drawn behind code by the CodeShadingAdorner overlay
         (not as the code's own background, so a theme recolour never re-formats the document). -->
    <SolidColorBrush x:Key="CodeShadingBrush" Color="#1EFFFFFF" />

    <!-- Change Highlight: the brief shade the ChangeHighlightAdorner draws behind what a live reload
         changed, and the stronger accent for a changed Block's leading edge and a deletion seam's
         tick. Lifted off the dark page rather than darkening it, so it reads as light on dark. -->
    <SolidColorBrush x:Key="ChangeHighlightBrush" Color="#3D7C6CF0" />
    <SolidColorBrush x:Key="ChangeHighlightMarkerBrush" Color="#9B8DFF" />

    <!-- Scrollbar thumb: the accent colour, muted at rest and full-strength on hover/drag. -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#7C6CF0" Opacity="0.55" />

    <SolidColorBrush x:Key="CaretBrush" Color="#E6E6E9" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#3B3564" />
    <SolidColorBrush x:Key="DirtyDotBrush" Color="#7C6CF0" />

    <SolidColorBrush x:Key="ConflictBackgroundBrush" Color="#3A2E12" />
    <SolidColorBrush x:Key="ConflictBorderBrush" Color="#A87A17" />
    <SolidColorBrush x:Key="ConflictTextBrush" Color="#F0D68A" />

    <!-- Conflict Difference: the line backgrounds and the -/+ markers of the View Difference
         overlay. Removed (-) is the Editor Session's unsaved side; added (+) is the on-disk side. -->
    <SolidColorBrush x:Key="DifferenceRemovedBrush" Color="#3B2528" />
    <SolidColorBrush x:Key="DifferenceRemovedTextBrush" Color="#FF8A8E" />
    <SolidColorBrush x:Key="DifferenceAddedBrush" Color="#22362A" />
    <SolidColorBrush x:Key="DifferenceAddedTextBrush" Color="#6FCF8A" />

    <SolidColorBrush x:Key="CloseHoverBrush" Color="#4A2A2C" />
    <SolidColorBrush x:Key="CloseHoverTextBrush" Color="#FF8A8E" />

</ResourceDictionary>
