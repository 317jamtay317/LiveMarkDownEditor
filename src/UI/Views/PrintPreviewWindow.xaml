<Window x:Class="UI.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UI.Controls"
        Title="Print preview"
        Width="1180" Height="820" MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

    <!-- The Print Preview: the whole document laid out into the very pages Print would produce, truly
         paginated under the one editor-wide Page Setup, with Print beside it. Previewing changes
         nothing (INV-061). -->
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="12,10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="Print…" Command="{Binding PrintCommand}"
                        Style="{StaticResource DialogButton}"
                        AutomationProperties.Name="Print" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                      Background="{DynamicResource EditorCanvasBrush}"
                      AutomationProperties.AutomationId="PrintPreviewCanvas">
            <controls:PrintPreviewPages Document="{Binding Document}" Setup="{Binding Setup}"
                                        Margin="28" HorizontalAlignment="Center"
                                        AutomationProperties.AutomationId="PrintPreviewPages" />
        </ScrollViewer>
    </DockPanel>
</Window>
