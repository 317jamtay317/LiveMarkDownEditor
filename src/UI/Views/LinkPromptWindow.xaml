<Window x:Class="UI.Views.LinkPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UI.Controls"
        Title="{Binding Title}"
        controls:DialogCloser.DialogResult="{Binding DialogResult}"
        Width="440" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource TextBrush}">

    <!-- The Link Prompt: the one place a URL is typed, because the Visual Document never shows raw
         [text](url) syntax. Accept is disabled until a URL is given — a Link is nothing without a
         destination (INV-030). -->
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding TextLabel}"
                   VerticalAlignment="Center" Margin="0,0,12,8" />
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Padding="4"
                 AutomationProperties.Name="{Binding TextLabel}"
                 Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding UrlLabel}"
                   VerticalAlignment="Center" Margin="0,0,12,8" />
        <!-- Focused on open: the text is usually seeded from the selection, so the URL is what the
             user came here to type. -->
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Padding="4"
                 AutomationProperties.Name="{Binding UrlLabel}"
                 controls:FocusOnVisible.Enabled="True"
                 Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" IsCancel="True" MinWidth="80" Padding="8,4" Margin="0,0,8,0"
                    AutomationProperties.Name="Cancel"
                    Command="{Binding CancelCommand}" />
            <Button Content="Insert" IsDefault="True" MinWidth="80" Padding="8,4"
                    AutomationProperties.Name="Insert"
                    Command="{Binding AcceptCommand}" />
        </StackPanel>
    </Grid>
</Window>
